---
import AuthorPage from "../../components/templates/AuthorPage.astro";
import { authorsConfig } from "../../lib/authors";

export const prerender = true;

export function getStaticPaths() {

    return Object.keys(authorsConfig).map((authorSlug) => ({
        params: { author: authorSlug },
    }));
}

const { author } = Astro.params;
---

<AuthorPage slug={author} />
