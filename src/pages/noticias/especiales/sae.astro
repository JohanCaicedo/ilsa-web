---
import Layout from "../../../layouts/Layout.astro";
import SmartImage from "../../../components/atoms/SmartImage.astro";
import GradientText from "../../../components/atoms/GradientText.astro";
import GalleryLightbox from "../../../components/molecules/GalleryLightbox.astro";
import {
    MapPin,
    Calendar,
    Video,
    Building2,
    Quote,
    ShieldCheck,
    Sparkles,
    Users,
    Heart,
    Home,
} from "lucide-react";
import type { SeoData } from "../../../lib/seo";

// Edge Caching (ISR) rule para Cloudflare
export const prerender = false;
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=3600, stale-while-revalidate=86400",
);

const breadcrumbs = [
    { label: "Noticias", href: "/noticias" },
    { label: "Especiales", href: "/noticias" },
    { label: "Bienes SAE - ILSA", href: "/noticias/especiales/sae" },
];

const seoData: SeoData = {
    title: "La SAE entrega siete inmuebles en Bogotá: ILSA entre las organizaciones seleccionadas | ILSA",
    metaDesc:
        "La Sociedad de Activos Especiales (SAE) entregó en Bogotá siete inmuebles incautados al narcotráfico y corrupción a diversas organizaciones sociales, entre ellas ILSA.",
    opengraphTitle:
        "Bienes que Transforman: La SAE entrega inmuebles para la paz y la memoria",
    opengraphDescription:
        "A través de 'Bienes que Transforman', la SAE entregó a organizaciones sociales como ILSA siete inmuebles en Bogotá anteriormente vinculados a economías ilícitas.",
    opengraphImage: {
        sourceUrl: "/images/sae/sae (4).webp",
    },
    twitterImage: {
        sourceUrl: "/images/sae/sae (4).webp",
    },
};

const organizations = [
    {
        name: "ILSA",
        fullName:
            "Instituto Latinoamericano para una Sociedad y un Derecho Alternativos",
        description:
            "Organización social seleccionada. Con la asignación del inmueble potenciará su labor histórica en la defense de los derechos humanos, el acceso a la justicia y el fortalecimiento comunitario en la región, consolidando su impacto en la construcción de paz y la transformación social.",
        highlight: true,
    },
    {
        name: "Corp. Claretiana Norman Pérez Bello",
        fullName: "Corporación Claretiana Norman Pérez Bello",
        description:
            "Organización social seleccionada. El inmueble asignado perteneció a un operador financiero del Cartel de Cali y ahora será un refugio dedicado a la protección de líderes sociales y defensores de derechos humanos.",
        symbolic: true,
    },
    {
        name: "FUNSAMACH",
        fullName: "Fundación Saberes Ancestrales Manyulo Chanapicama",
        description:
            "Organización social seleccionada mediante invitación pública para recibir uno de los siete inmuebles destinados a proyectos sociales, culturales y de memoria.",
        symbolic: false,
    },
    {
        name: "Asociación Cultural Vuelo",
        fullName: "Asociación Cultural Vuelo",
        description:
            "Colectivo social seleccionado mediante invitación pública para recibir uno de los siete inmuebles destinados a proyectos sociales, culturales y de memoria.",
        symbolic: false,
    },
    {
        name: "Arte Acción Colombia",
        fullName: "Arte Acción Colombia",
        description:
            "Colectivo social seleccionado mediante invitación pública para recibir uno de los siete inmuebles destinados a proyectos sociales, culturales y de memoria.",
        symbolic: false,
    },
    {
        name: "COARCOS",
        fullName: "Corporación para el Arte y el Conocimiento del Ser",
        description:
            "Corporación seleccionada mediante invitación pública para recibir uno de los siete inmuebles destinados a proyectos sociales, culturales y de memoria.",
        symbolic: false,
    },
    {
        name: "Fundación Integrando Fronteras",
        fullName: "Fundación Integrando Fronteras",
        description:
            "Fundación seleccionada mediante invitación pública para recibir uno de los siete inmuebles destinados a proyectos sociales, culturales y de memoria.",
        symbolic: false,
    },
];

const galleryImages = [
    {
        src: "/images/sae/sae (4).webp",
        alt: "Acto oficial de entrega de inmuebles de la SAE a ILSA y organizaciones aliadas",
    },
    {
        src: "/images/sae/HLTDbeqXAAASGRI.jpeg",
        alt: "Acto oficial de entrega de inmuebles de la SAE a ILSA y organizaciones aliadas 1",
    },
    {
        src: "/images/sae/sae (1).webp",
        alt: "Representantes de organizaciones sociales y directivos de la SAE en Bogotá",
    },
    {
        src: "/images/sae/sae (5).webp",
        alt: "Entrega física de los inmuebles que ahora serán centros de memoria y derechos humanos",
    },
    {
        src: "/images/sae/sae (6).webp",
        alt: "Directivas de ILSA y participantes celebrando la asignación del nuevo espacio de trabajo",
    },
];
---

<Layout
    title="Especial: Entrega de Bienes SAE - ILSA"
    width="wide"
    seo={seoData}
    breadcrumbs={breadcrumbs}
>
    <div class="relative min-h-screen pb-32">
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            <div
                class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-[var(--ilsa-blue-light)]/10 rounded-full blur-[120px] animate-blob"
            >
            </div>
            <div
                class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-[var(--ilsa-mujeres-light)]/10 rounded-full blur-[100px] animate-blob animation-delay-2000"
            >
            </div>
        </div>

        <div class="relative z-10 pt-8 max-w-5xl mx-auto px-4 md:px-8">
            <div class="text-center mb-16 space-y-6">
                <div
                    class="inline-flex items-center justify-center gap-3 px-5 py-2.5 rounded-full bg-white/60 backdrop-blur-md border border-[var(--ilsa-blue-dark)]/25 shadow-sm mx-auto"
                >
                    <span class="relative flex h-2.5 w-2.5">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--ilsa-blue-dark)] opacity-40"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[var(--ilsa-blue-dark)]"
                        ></span>
                    </span>
                    <span
                        class="text-xs font-bold text-[var(--ilsa-blue-dark)] uppercase tracking-[0.2em]"
                    >
                        Reporte Especial
                    </span>
                </div>

                <h1
                    class="text-4xl md:text-6xl text-center font-black drop-shadow-sm leading-[1.1] text-balance mx-auto text-slate-800"
                >
                    <GradientText
                        text="Bienes que Transforman:"
                        size="text-4xl md:text-6xl"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="var(--ilsa-blue-dark)"
                        asSpan={true}
                    />
                    <br />
                    Bienes para la Memoria y la Paz
                </h1>

                <p
                    class="text-lg md:text-xl text-center text-slate-600 max-w-3xl mx-auto text-balance leading-relaxed font-light mt-4"
                >
                    La SAE entrega siete inmuebles en Bogotá para fortalecer
                    proyectos sociales, culturales y de memoria: <strong
                        class="text-slate-800 font-semibold"
                        >ILSA entre las organizaciones seleccionadas.</strong
                    >
                </p>

                <div
                    class="flex flex-wrap items-center justify-center gap-6 pt-4 text-sm text-slate-500 font-medium"
                >
                    <div
                        class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-full border border-white/60 backdrop-blur-sm shadow-sm"
                    >
                        <MapPin className="w-4 h-4 text-[var(--ilsa-blue)]" />
                        <span>Bogotá, Colombia</span>
                    </div>
                    <div
                        class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-full border border-white/60 backdrop-blur-sm shadow-sm"
                    >
                        <Calendar className="w-4 h-4 text-[var(--ilsa-blue)]" />
                        <span>23 de junio, 2026</span>
                    </div>
                    <div
                        class="flex items-center gap-2 bg-white/50 px-4 py-2 rounded-full border border-white/60 backdrop-blur-sm shadow-sm"
                    >
                        <Building2
                            className="w-4 h-4 text-[var(--ilsa-blue)]"
                        />
                        <span>7 Inmuebles Entregados</span>
                    </div>
                </div>
            </div>

            <div
                class="bg-white/50 backdrop-blur-3xl border border-white/60 shadow-2xl shadow-slate-200/50 rounded-[3rem] p-6 md:p-12 space-y-16"
            >
                <div
                    class="w-full aspect-[16/9] md:h-[500px] rounded-[2.5rem] overflow-hidden shadow-xl border border-white/80 relative group"
                >
                    <SmartImage
                        src="/images/sae/sae (4).webp"
                        alt="Acto de entrega oficial de bienes por la SAE"
                        class="w-full h-full object-cover object-center group-hover:scale-102 transition-transform duration-1000"
                        priority={true}
                        width={1200}
                        height={675}
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-slate-950/45 to-transparent"
                    >
                    </div>
                    <div
                        class="absolute bottom-6 left-6 right-6 text-white text-sm md:text-base font-light bg-black/30 backdrop-blur-sm px-5 py-3 rounded-2xl border border-white/10 max-w-max"
                    >
                        Entrega de activos de economías ilícitas al tejido
                        social de Bogotá.
                    </div>
                </div>

                <section
                    class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 items-stretch pt-4"
                >
                    <div
                        class="space-y-6 text-slate-700 leading-relaxed text-lg font-light text-pretty"
                    >
                        <p
                            class="text-xl text-slate-800 font-normal leading-relaxed"
                        >
                            En un paso clave para el fortalecimiento del tejido
                            social y la defense de los derechos humanos, la
                            Sociedad de Activos Especiales (SAE) entregó a
                            organizaciones localizadas en Bogotá, <strong
                                class="text-[var(--ilsa-blue-dark)] font-semibold"
                                >siete inmuebles</strong
                            > que anteriormente estaban vinculados a economías ilícitas,
                            narcotráfico y corrupción.
                        </p>
                        <p>
                            A través de las iniciativas <strong
                                class="text-slate-800 font-medium"
                                >"Bienes que Transforman"</strong
                            > y <strong class="text-slate-800 font-medium"
                                >"Activos para la Memoria"</strong
                            >, el Gobierno Nacional asignó estos espacios a
                            diversas organizaciones sociales seleccionadas
                            mediante invitación pública.
                        </p>
                        <p>
                            Con esta jornada, la SAE reafirma su compromiso de
                            transformar los activos incautados a la criminalidad
                            en herramientas vivas al servicio de la paz, la
                            cultura y la memoria, permitiendo que organizaciones
                            con la trayectoria de <strong
                                class="text-slate-800 font-medium">ILSA</strong
                            > cuenten con espacios para desplegar acciones de la mano
                            de procesos organizativos de víctimas, mujeres, sectores
                            vulnerabilizados y población rural.
                        </p>
                    </div>

                    <div
                        class="relative bg-gradient-to-br from-white/70 to-white/40 backdrop-blur-2xl rounded-3xl border border-white/80 shadow-xl overflow-hidden p-8 flex flex-col"
                    >
                        <div
                            class="absolute -top-16 -right-16 w-48 h-48 bg-[var(--ilsa-blue-dark)]/5 rounded-full blur-[120px] pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute inset-x-0 bottom-0 h-1.5 bg-gradient-to-r from-gradient-to-r from-[var(--ilsa-blue)] via-[var(--ilsa-blue-dark)] to-[var(--ilsa-mujeres)]"
                        >
                        </div>

                        <h3
                            class="text-xl font-black text-slate-800 flex items-center justify-center lg:justify-start gap-2 mb-3 text-center lg:text-left"
                        >
                            <Sparkles
                                className="w-5 h-5 shrink-0 text-[var(--ilsa-blue)]"
                            />
                            Impacto del Proyecto
                        </h3>

                        <div class="space-y-6">
                            <div
                                class="flex flex-col sm:flex-row items-center lg:items-start gap-5 text-center sm:text-left"
                            >
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-[var(--ilsa-blue)]/10 flex items-center justify-center border border-white/40 shadow-sm"
                                >
                                    <span
                                        class="text-2xl font-black text-[var(--ilsa-blue)]"
                                        >7</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-wider"
                                    >
                                        Inmuebles Asignados
                                    </div>
                                    <div class="text-xs text-slate-500">
                                        Ubicados estratégicamente en Bogotá
                                    </div>
                                </div>
                            </div>

                            <div
                                class="flex flex-col sm:flex-row items-center lg:items-start gap-5 text-center sm:text-left"
                            >
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-[var(--ilsa-mujeres)]/10 flex items-center justify-center border border-white/40 shadow-sm"
                                >
                                    <span
                                        class="text-2xl font-black text-[var(--ilsa-mujeres)]"
                                        >2</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-wider"
                                    >
                                        Programas de Estado
                                    </div>
                                    <div class="text-xs text-slate-500">
                                        Bienes que Transforman / Activos para la
                                        Memoria
                                    </div>
                                </div>
                            </div>

                            <div
                                class="flex flex-col sm:flex-row items-center lg:items-start gap-5 text-center sm:text-left"
                            >
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-teal-500/10 flex items-center justify-center border border-white/40 shadow-sm"
                                >
                                    <span
                                        class="text-2xl font-black text-teal-600"
                                        >1</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-wider"
                                    >
                                        Destino Común
                                    </div>
                                    <div class="text-xs text-slate-500">
                                        Construcción de paz, DDHH y memoria viva
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="relative py-4">
                    <div
                        class="w-full h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent"
                    >
                    </div>
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-white border border-slate-200 rounded-full flex items-center justify-center shadow-sm"
                    >
                        <div class="w-2 h-2 bg-[var(--ilsa-blue)] rounded-full">
                        </div>
                    </div>
                </div>

                <section class="space-y-8">
                    <div class="text-center max-w-2xl mx-auto mb-8">
                        <div
                            class="inline-flex items-center gap-2 bg-[var(--ilsa-blue)]/5 text-[var(--ilsa-blue-dark)] text-xs font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full mb-3 border border-[var(--ilsa-blue)]/10 mx-auto"
                        >
                            <Video className="w-3.5 h-3.5" />
                            Palabras de la Dirección
                        </div>
                        <h2
                            class="text-3xl font-black text-slate-800 tracking-tight text-center"
                        >
                            Intervención de Nuestro Director
                        </h2>
                    </div>

                    <div
                        class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center"
                    >
                        <div class="lg:col-span-5 flex justify-center w-full">
                            <div
                                class="relative w-full max-w-[320px] bg-white/40 p-3 rounded-[2.5rem] border border-white/80 shadow-xl overflow-hidden backdrop-blur-xl"
                            >
                                <div
                                    class="absolute inset-0 -z-10 bg-gradient-to-br from-white to-slate-100/50"
                                >
                                </div>

                                <div
                                    class="relative w-full aspect-[9/16] rounded-[1.8rem] overflow-hidden bg-slate-950 shadow-inner group"
                                >
                                    <video
                                        src="/images/sae/Palabras-Freddy_1.webm"
                                        controls
                                        preload="metadata"
                                        class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-700"
                                        playsinline
                                    >
                                        Su navegador no soporta reproducción de
                                        video local HTML5.
                                    </video>
                                </div>
                            </div>
                        </div>

                        <div
                            class="lg:col-span-7 relative flex flex-col justify-center p-8 md:p-10 bg-gradient-to-br from-[var(--ilsa-blue-dark)]/5 to-[var(--ilsa-blue)]/[0.02] rounded-[2.5rem] border border-[var(--ilsa-blue-dark)]/10 shadow-lg min-h-[300px]"
                        >
                            <div
                                class="absolute top-6 left-6 text-[var(--ilsa-blue)]/10 pointer-events-none"
                            >
                                <Quote className="w-16 h-16 fill-current" />
                            </div>

                            <blockquote
                                class="relative z-10 text-center lg:text-left text-slate-700 text-base md:text-lg font-light italic leading-relaxed pt-6 lg:pt-0"
                            >
                                "El trabajo que desde 1978 ha adelantado ILSA se
                                orienta a la transformación de la sociedad a
                                partir del uso del derecho para garantizar tanto
                                el estado social de derecho, como los derechos
                                de todos los sectores subalternos de la
                                sociedad. Sin lugar a dudas este bien
                                contribuirá a esa tarea en el sentido de poder
                                desarrollar procesos pedagógicos y abogacía *
                                popular con actorias sociales, como las víctimas
                                del conflicto. Para construir paz y para
                                cerrarle los espacios a la violencia"
                            </blockquote>

                            <div
                                class="mt-8 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 border-t border-slate-200/60 pt-5 text-center sm:text-left"
                            >
                                <div
                                    class="w-12 h-12 shrink-0 rounded-2xl bg-gradient-to-tr from-[var(--ilsa-blue)] to-[var(--ilsa-blue-dark)] flex items-center justify-center text-white font-bold text-lg shadow-md border border-white/20 select-none"
                                >
                                    FO
                                </div>
                                <div>
                                    <h4
                                        class="font-extrabold text-slate-800 leading-tight"
                                    >
                                        Freddy Ordóñez Gómez
                                    </h4>
                                    <p
                                        class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-0.5"
                                    >
                                        Director Ejecutivo ILSA
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="relative py-4">
                    <div
                        class="w-full h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent"
                    >
                    </div>
                </div>

                <section
                    class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center"
                >
                    <div
                        class="lg:col-span-5 space-y-6 text-center lg:text-left"
                    >
                        <div
                            class="inline-flex items-center gap-2 bg-teal-500/5 text-teal-700 text-xs font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full border border-teal-500/10 mx-auto lg:mx-0"
                        >
                            <ShieldCheck className="w-3.5 h-3.5" />
                            Impacto Institucional
                        </div>
                        <h2
                            class="text-3xl md:text-4xl font-black text-slate-800 tracking-tight leading-tight"
                        >
                            ILSA entre las organizaciones seleccionadas
                        </h2>
                        <div
                            class="text-slate-600 leading-relaxed font-light space-y-4"
                        >
                            <p>
                                Entre las entidades destaca de manera especial
                                el <strong class="text-slate-800 font-medium"
                                    >Instituto Latinoamericano para una Sociedad
                                    y un Derecho Alternativos (ILSA)</strong
                                >. Con la asignación de uno de estos inmuebles,
                                ILSA potenciará su labor histórica en la defense
                                de los derechos humanos, el acceso a la justicia
                                y el fortalecimiento comunitario en la región.
                            </p>
                            <p>
                                Este nuevo espacio se convertirá en un punto
                                estratégico para robustecer los procesos de
                                formación, investigación y acompañamiento,
                                consolidando su impacto en la construcción de
                                paz y la transformación social desde la práctica
                                legal crítica.
                            </p>
                        </div>
                    </div>

                    <div class="lg:col-span-7">
                        <div
                            class="relative rounded-[2.5rem] overflow-hidden aspect-[4/3] md:aspect-[16/10] border border-white/80 shadow-lg group"
                        >
                            <SmartImage
                                src="/images/sae/sae (1).webp"
                                alt="Representantes de la SAE entregando las llaves del inmueble a ILSA"
                                class="w-full h-full object-cover object-center group-hover:scale-102 transition-transform duration-700"
                                width={800}
                                height={500}
                            />
                        </div>
                    </div>
                </section>

                <section class="space-y-8">
                    <div class="text-center max-w-2xl mx-auto">
                        <div
                            class="inline-flex items-center gap-2 bg-emerald-500/5 text-emerald-700 text-xs font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full mb-3 border border-emerald-500/10 mx-auto"
                        >
                            <Sparkles className="w-3.5 h-3.5" />
                            Registro Fotográfico
                        </div>
                        <h2
                            class="text-3xl font-black text-slate-800 tracking-tight text-center"
                        >
                            Galería del Evento
                        </h2>
                        <p class="text-slate-500 text-sm mt-1">
                            Haz clic sobre cualquier imagen para abrir el visor
                            en alta resolución.
                        </p>
                    </div>

                    <GalleryLightbox>
                        <div
                            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 px-4 md:px-0"
                        >
                            {
                                galleryImages.map((img, idx) => (
                                    <button
                                        type="button"
                                        class="gallery-thumb break-inside-avoid relative rounded-[2rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 group border border-white/80 bg-white/50 backdrop-blur-sm cursor-zoom-in block w-full aspect-[4/3] text-left"
                                        data-index={idx}
                                        aria-label={`Ver foto ${idx + 1} de la entrega de bienes SAE`}
                                    >
                                        <SmartImage
                                            src={img.src}
                                            alt={img.alt}
                                            class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-103"
                                            width={500}
                                            height={375}
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400 pointer-events-none" />

                                        <div class="absolute bottom-4 left-4 right-4 text-white text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-300 truncate">
                                            {img.alt}
                                        </div>

                                        <div class="absolute top-3 right-3 bg-white/80 backdrop-blur-sm rounded-full p-2.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-md">
                                            <svg
                                                class="w-4 h-4 text-slate-700"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2.5"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
