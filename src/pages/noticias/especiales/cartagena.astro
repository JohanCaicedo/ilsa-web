---
import Layout from "../../../layouts/Layout.astro";
import LiquidContainer from "../../../components/experimental/LiquidContainer.astro";
import GradientText from "../../../components/atoms/GradientText.astro";
import YoutubeEmbed from "../../../components/atoms/YoutubeEmbed.astro";
import Breadcrumbs from "../../../components/atoms/Breadcrumbs.astro";
import GalleryLightbox from "../../../components/molecules/GalleryLightbox.astro";
import type { SeoData } from "../../../lib/seo";

const breadcrumbs = [
    { label: "Noticias", href: "/noticias" },
    { label: "Especiales", href: "/noticias" },
    { label: "ICARRD+20 Cartagena", href: "/noticias/especiales/cartagena" },
];

const speakers = [
    {
        name: "José Luis Quiroga",
        role: "Viceministro de Desarrollo Rural (MADR)",
    },
    {
        name: "Juan Camilo Morales S.",
        role: "Defensor del Pueblo Delegado (Tierras)",
    },
    {
        name: "Jhenifer Mojica",
        role: "Embajadora de la Misión Permanente de Colombia (FAO)",
    },
    {
        name: "Cristina Luna Calpa",
        role: "Experta en Derechos Territoriales Indígenas",
    },
    { name: "Freddy Ordóñez Gómez", role: "Director Ejecutivo ILSA" },
    { name: "Mayerly Diaz", role: "Investigadora ILSA (Moderadora)" },
];

const seoData: SeoData = {
    title: "Dificultades y Desafíos de la Reforma Rural Integral | ICARRD+20 Cartagena — ILSA",
    metaDesc:
        "Conversatorio sobre las dificultades y desafíos de la Reforma Rural Integral en Colombia, realizado el 27 de febrero de 2026 en Cartagena en el marco de la ICARRD+20. Organizado por ILSA.",
    opengraphTitle:
        "Dificultades y Desafíos de la Reforma Rural Integral — ILSA",
    opengraphDescription:
        "Revive el diálogo histórico sobre reforma agraria entre el Gobierno Nacional, el movimiento social y la academia en la ICARRD+20 Cartagena.",
    opengraphImage: {
        sourceUrl:
            "https://ilsa.org.co/images/evento-cartagena/Convesatorio-portada.webp",
    },
};

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "Dificultades y Desafíos de la Reforma Rural Integral",
    description:
        "Conversatorio sobre las dificultades y desafíos de la Reforma Rural Integral en Colombia, organizado por ILSA en el marco de la ICARRD+20.",
    startDate: "2026-02-27T14:00:00-05:00",
    endDate: "2026-02-27T15:30:00-05:00",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    eventStatus: "https://schema.org/EventScheduled",
    location: {
        "@type": "Place",
        name: "Corporación Universitaria Rafael Núñez",
        address: {
            "@type": "PostalAddress",
            addressLocality: "Cartagena",
            addressRegion: "Bolívar",
            addressCountry: "CO",
        },
    },
    organizer: {
        "@type": "Organization",
        name: "ILSA – Instituto Latinoamericano para una Sociedad y un Derecho Alternativos",
        url: "https://ilsa.org.co",
    },
    performer: speakers.map((s) => ({
        "@type": "Person",
        name: s.name,
        jobTitle: s.role,
    })),
    image: "https://ilsa.org.co/images/evento-cartagena/Convesatorio-portada.webp",
};
---

<Layout
    title="Especial: ICARRD+20 Cartagena - ILSA"
    width="wide"
    seo={seoData}
    breadcrumbs={breadcrumbs}
>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <div class="relative min-h-screen pb-32">
        <div class="fixed inset-0 z-0 h-screen w-full bg-slate-50">
            <LiquidContainer
                class="absolute inset-0 w-full h-full opacity-60 mix-blend-multiply"
                intensity="medium"
                use3D={true}
                frosted={true}
                clipContent={false}
            />
        </div>

        <div class="relative z-10 pt-12 max-w-5xl mx-auto px-4 md:px-8">
            <div class="text-center mb-16 space-y-8">
                <div
                    class="inline-flex items-center justify-center gap-3 px-5 py-2.5 rounded-full bg-white/60 backdrop-blur-md border border-[var(--ilsa-blue-dark)]/30 shadow-sm mb-4"
                >
                    <span class="relative flex h-2.5 w-2.5">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--ilsa-blue-dark)] opacity-30"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[var(--ilsa-blue-dark)]"
                        ></span>
                    </span>
                    <span
                        class="text-xs font-bold text-[var(--ilsa-blue-dark)] uppercase tracking-[0.2em]"
                    >
                        Reporte de Evento
                    </span>
                </div>

                <h1
                    class="text-5xl md:text-7xl text-center font-black drop-shadow-sm leading-[1.1] text-balance mx-auto"
                >
                    <GradientText
                        text="Dificultades y Desafíos"
                        size="text-5xl md:text-7xl"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="var(--ilsa-blue-dark)"
                        asSpan={true}
                    />
                    <br class="hidden md:block" />
                    <GradientText
                        text="de la Reforma Rural Integral"
                        size="text-5xl md:text-7xl"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="var(--ilsa-blue-dark)"
                        asSpan={true}
                    />
                </h1>

                <p
                    class="text-lg md:text-2xl text-slate-600 max-w-3xl mx-auto text-balance leading-relaxed font-light"
                >
                    Un diálogo histórico entre el Gobierno Nacional, el
                    movimiento social y la academia en el marco de la <span
                        class="text-[var(--ilsa-blue)] font-medium"
                        >ICARRD+20</span
                    > en Cartagena.
                </p>
            </div>

            <div
                class="stagger-2 w-full mb-24 aspect-video rounded-3xl overflow-hidden shadow-xl border border-white/80 relative group"
            >
                <img
                    src="/images/evento-cartagena/Convesatorio-portada.webp"
                    alt="Conversatorio Dificultades y Desafíos de la Reforma Rural Integral — ICARRD+20 Cartagena, 27 de febrero de 2026"
                    fetchpriority="high"
                    width="1200"
                    height="675"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent"
                >
                </div>
            </div>

            <section class="stagger-3 max-w-3xl mx-auto mb-24 px-4 text-center">
                <p
                    class="text-lg md:text-xl text-slate-500 leading-relaxed text-balance"
                >
                    Hace más de 45 años, ILSA camina junto a los movimientos
                    populares. El pasado <strong class="text-slate-700"
                        >27 de febrero</strong
                    >, en Cartagena, abrimos un espacio de encuentro para
                    dialogar sobre los avances, desafíos y dificultades
                    estructurales de la reforma agraria.
                </p>
            </section>

            <section class="max-w-4xl mx-auto mb-24 px-4">
                <div
                    class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-center"
                >
                    <div>
                        <p
                            class="text-xl font-medium text-slate-700 leading-relaxed text-balance text-center lg:text-left mb-6"
                        >
                            La democratización de la tierra y la cuestión
                            agraria exigen nuevas formas de repensar la relación
                            entre la ciudadanía y el Estado.
                        </p>
                        <p
                            class="text-lg text-slate-500 leading-relaxed text-balance text-center lg:text-left"
                        >
                            Pese a las conquistas históricas en dotación de
                            tierras y el reconocimiento del campesinado como
                            sujeto de derechos, la reforma rural integral sigue
                            enfrentando profundos obstáculos para materializar
                            una vida digna.
                        </p>
                    </div>

                    <div
                        class="relative bg-white/60 backdrop-blur-2xl rounded-3xl border border-white/80 shadow-xl overflow-hidden p-8 lg:p-10"
                    >
                        <div
                            class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-[var(--ilsa-blue)] via-[var(--ilsa-blue-dark)] to-[var(--ilsa-mujeres)]"
                        >
                        </div>
                        <div
                            class="absolute -top-16 -right-16 w-48 h-48 bg-[var(--ilsa-blue-dark)]/8 rounded-full blur-3xl pointer-events-none"
                        >
                        </div>

                        <div class="relative z-10 flex flex-col gap-7">
                            <div class="flex items-center gap-5">
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-[var(--ilsa-blue-dark)]/10 flex items-center justify-center border border-white"
                                >
                                    <span
                                        class="text-xl font-black text-[var(--ilsa-blue-dark)]"
                                        >45+</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-widest"
                                    >
                                        Años
                                    </div>
                                    <div class="text-sm text-slate-500">
                                        De trayectoria e historia
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-5">
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-[var(--ilsa-mujeres)]/10 flex items-center justify-center border border-white"
                                >
                                    <span
                                        class="text-xl font-black text-[var(--ilsa-mujeres)]"
                                        >90</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-widest"
                                    >
                                        Minutos
                                    </div>
                                    <div class="text-sm text-slate-500">
                                        De diálogo intenso
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-5">
                                <div
                                    class="w-14 h-14 shrink-0 rounded-2xl bg-slate-900/5 flex items-center justify-center border border-white"
                                >
                                    <span
                                        class="text-xl font-black text-slate-700"
                                        >6</span
                                    >
                                </div>
                                <div>
                                    <div
                                        class="text-sm font-bold text-slate-800 uppercase tracking-widest"
                                    >
                                        Panelistas
                                    </div>
                                    <div class="text-sm text-slate-500">
                                        Expertos en el tema
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="max-w-4xl mx-auto mb-24 px-4">
                <div
                    class="relative bg-white/60 backdrop-blur-2xl rounded-3xl border border-white/80 shadow-xl overflow-hidden"
                >
                    <div
                        class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-[var(--ilsa-blue)] via-[var(--ilsa-blue-dark)] to-[var(--ilsa-mujeres)]"
                    >
                    </div>
                    <div
                        class="absolute -top-16 -right-16 w-48 h-48 bg-[var(--ilsa-blue-dark)]/8 rounded-full blur-3xl pointer-events-none"
                    >
                    </div>
                    <div
                        class="absolute -bottom-16 -left-16 w-40 h-40 bg-[var(--ilsa-mujeres)]/8 rounded-full blur-3xl pointer-events-none"
                    >
                    </div>

                    <div class="p-8 md:p-10 relative z-10">
                        <div class="flex items-center gap-3 mb-6">
                            <div
                                class="w-10 h-10 rounded-xl bg-[var(--ilsa-blue-dark)]/10 flex items-center justify-center shrink-0"
                            >
                                <svg
                                    class="w-5 h-5 text-[var(--ilsa-blue-dark)]"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path></svg
                                >
                            </div>
                            <h2
                                class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight"
                            >
                                El Eje del Debate
                            </h2>
                        </div>

                        <p
                            class="text-slate-600 text-lg leading-relaxed mb-8 text-balance"
                        >
                            Un diálogo necesario entre institucionalidad,
                            academia y movimiento social para dilucidar
                            perspectivas conjuntas: ¿Cómo impacta la acaparación
                            y extranjerización de tierras en las
                            territorialidades campesinas, indígenas y
                            afrodescendientes?
                        </p>

                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div
                                class="group flex flex-col gap-3 bg-white/60 backdrop-blur-xl rounded-2xl p-5 border border-white/80 hover:shadow-lg transition-all duration-300"
                            >
                                <div
                                    class="w-9 h-9 rounded-lg bg-[var(--ilsa-blue-dark)]/10 flex items-center justify-center group-hover:bg-[var(--ilsa-blue-dark)]/15 transition-colors"
                                >
                                    <svg
                                        class="w-4.5 h-4.5 text-[var(--ilsa-blue-dark)]"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                        ></path></svg
                                    >
                                </div>
                                <div>
                                    <h4
                                        class="font-bold text-slate-800 text-sm"
                                    >
                                        Entrega y Formalización
                                    </h4>
                                    <p class="text-xs text-slate-500 mt-1">
                                        de tierras
                                    </p>
                                </div>
                            </div>
                            <div
                                class="group flex flex-col gap-3 bg-white/60 backdrop-blur-xl rounded-2xl p-5 border border-white/80 hover:shadow-lg transition-all duration-300"
                            >
                                <div
                                    class="w-9 h-9 rounded-lg bg-[var(--ilsa-blue-dark)]/10 flex items-center justify-center group-hover:bg-[var(--ilsa-blue-dark)]/15 transition-colors"
                                >
                                    <svg
                                        class="w-4.5 h-4.5 text-[var(--ilsa-blue-dark)]"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                                        ></path></svg
                                    >
                                </div>
                                <div>
                                    <h4
                                        class="font-bold text-slate-800 text-sm"
                                    >
                                        Productividad
                                    </h4>
                                    <p class="text-xs text-slate-500 mt-1">
                                        e impulso rural
                                    </p>
                                </div>
                            </div>
                            <div
                                class="group flex flex-col gap-3 bg-white/60 backdrop-blur-xl rounded-2xl p-5 border border-white/80 hover:shadow-lg transition-all duration-300"
                            >
                                <div
                                    class="w-9 h-9 rounded-lg bg-[var(--ilsa-blue-dark)]/10 flex items-center justify-center group-hover:bg-[var(--ilsa-blue-dark)]/15 transition-colors"
                                >
                                    <svg
                                        class="w-4.5 h-4.5 text-[var(--ilsa-blue-dark)]"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        ></path><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path></svg
                                    >
                                </div>
                                <div>
                                    <h4
                                        class="font-bold text-slate-800 text-sm"
                                    >
                                        Zonas de Reserva
                                    </h4>
                                    <p class="text-xs text-slate-500 mt-1">
                                        Campesina (ZRC)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="max-w-5xl mx-auto mb-24 -mx-4 md:mx-auto">
                <div class="text-center mb-12 px-4">
                    <GradientText
                        text="Datos Clave del Acuerdo"
                        size="text-2xl md:text-3xl"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="var(--ilsa-blue-dark)"
                        class="mb-4 justify-center"
                    />
                    <p class="text-slate-600 max-w-2xl mx-auto text-balance">
                        Conoce las cifras actuales sobre la entrega de tierras y
                        la ampliación hasta el 2037 del plazo de implementación
                        de los PDET, un paso decisivo para la construcción de la
                        paz.
                    </p>
                </div>
                <div
                    class="flex overflow-x-auto gap-4 md:gap-6 snap-x snap-mandatory px-4 pb-6 hide-scrollbar"
                >
                    {
                        [1, 2, 3].map((n) => (
                            <div class="snap-center shrink-0 w-[80vw] md:w-[30%] relative rounded-3xl overflow-hidden shadow-xl border border-white/80 aspect-[4/5] group hover:shadow-2xl hover:-translate-y-1 transition-all duration-500">
                                <img
                                    src={`/images/evento-cartagena/redes/cartagena-redes (${n}).webp`}
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                    alt={`Infografía sobre las cifras de la Reforma Rural Integral y los PDET — Imagen ${n}`}
                                    width="800"
                                    height="1000"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
                            </div>
                        ))
                    }
                </div>
                <div
                    class="flex md:hidden items-center justify-center gap-2 mt-2"
                >
                    <span
                        class="text-xs text-slate-400 font-bold tracking-widest uppercase"
                        >Desliza</span
                    >
                    <svg
                        class="w-4 h-4 text-slate-400 animate-pulse"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                    >
                </div>
            </section>

            <section class="max-w-4xl mx-auto mb-24 px-4">
                <div
                    class="relative bg-white/60 backdrop-blur-2xl rounded-3xl border border-white/80 shadow-xl overflow-hidden p-8 md:p-12"
                >
                    <div
                        class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-[var(--ilsa-blue)] via-[var(--ilsa-blue-dark)] to-[var(--ilsa-mujeres)]"
                    >
                    </div>
                    <div
                        class="absolute -top-16 -right-16 w-48 h-48 bg-[var(--ilsa-blue-dark)]/8 rounded-full blur-3xl pointer-events-none"
                    >
                    </div>

                    <div
                        class="relative z-10 flex flex-col md:flex-row items-center md:items-start gap-8"
                    >
                        <div
                            class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-[var(--ilsa-blue)] to-[var(--ilsa-blue-dark)] shadow-lg shadow-[var(--ilsa-blue-dark)]/20 flex items-center justify-center"
                        >
                            <svg
                                class="w-6 h-6 text-white"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"
                                ></path></svg
                            >
                        </div>

                        <div class="text-center md:text-left">
                            <GradientText
                                text="Las Voces que Hicieron Eco"
                                size="text-3xl md:text-4xl"
                                weight="font-black"
                                from="var(--ilsa-blue)"
                                to="var(--ilsa-blue-dark)"
                                class="mb-4 justify-center md:justify-start"
                            />
                            <p
                                class="text-lg md:text-xl text-slate-600 max-w-2xl leading-relaxed text-balance"
                            >
                                Durante <strong class="text-slate-800"
                                    >90 minutos</strong
                                > de intenso diálogo, conectamos visiones desde el
                                alto gobierno hasta el liderazgo campesino y étnico,
                                apostando por una transformación sustentable y ecológica
                                para la autonomía de los territorios en Colombia.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-24 pt-10 relative">
                <div
                    class="absolute -top-20 left-1/2 -translate-x-1/2 w-[400px] h-[250px] bg-[var(--ilsa-blue-dark)]/8 rounded-full blur-3xl pointer-events-none"
                >
                </div>

                <div class="text-center mb-12">
                    <GradientText
                        text="Galería del Evento"
                        size="text-3xl md:text-5xl"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="var(--ilsa-blue-dark)"
                        class="justify-center mb-4"
                    />
                    <p
                        class="text-base md:text-lg text-slate-500 max-w-2xl mx-auto text-balance leading-relaxed"
                    >
                        Momentos capturados del diálogo social e institucional
                        sobre la Reforma Rural Integral en el marco de la <strong
                            class="text-slate-700">ICARRD+20</strong
                        >.
                    </p>
                </div>

                <GalleryLightbox>
                    <div
                        class="columns-2 md:columns-3 lg:columns-4 gap-3 md:gap-4 px-4 md:px-0"
                    >
                        {
                            Array.from({ length: 21 }).map((_, i) => (
                                <button
                                    type="button"
                                    class="gallery-thumb break-inside-avoid mb-3 md:mb-4 relative rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 group border border-white/80 bg-white/50 backdrop-blur-sm cursor-zoom-in block w-full text-left"
                                    data-index={i}
                                    aria-label={`Ver foto ${i + 1} del evento ICARRD+20 Cartagena en grande`}
                                >
                                    <img
                                        src={`/images/evento-cartagena/evento-cartagena (${i + 1}).jpg`}
                                        alt={`Conversatorio Reforma Rural Integral ICARRD+20 Cartagena — Foto ${i + 1} de 21`}
                                        class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                                        loading={i < 4 ? "eager" : "lazy"}
                                    />
