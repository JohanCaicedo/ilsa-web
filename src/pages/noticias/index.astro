---
import Layout from "../../layouts/Layout.astro";
import { getPostsByCategory } from "../../lib/wp";
import AuthorCard from "../../components/molecules/AuthorCard.astro";
import Pagination from "../../components/molecules/Pagination.astro";
import WPLoader from "../../components/molecules/WPLoader.astro";

import GradientText from "../../components/atoms/GradientText.astro";
import LiquidContainer from "../../components/experimental/LiquidContainer.astro";

// Switch to SSR to support dynamic pagination or params if needed
export const prerender = false;

// Cloudflare Edge Caching (ISR): Serve from Edge cache for 1 hr, revalidate in background for 1 day
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=3600, stale-while-revalidate=86400",
);

// Fetch news posts dynamically
const allNews = await getPostsByCategory("noticias", 100);

// Pagination Logic
const postsPerPage = 9;
const totalPages = Math.ceil(allNews.length / postsPerPage);
const gridId = "news-grid";
const cardClass = "news-card";
---

<Layout title="Noticias - ILSA" width="wide">
    <div
        class="relative pb-32 overflow-hidden selection:bg-blue-100 selection:text-blue-900"
    >
        <!-- Light Liquid Background -->
        <div class="fixed inset-0 z-0 h-screen w-full bg-slate-50">
            <LiquidContainer
                class="absolute inset-0 w-full h-full opacity-60 mix-blend-multiply"
                intensity="medium"
                use3D={true}
                frosted={true}
                clipContent={false}
            />
            <!-- Additional Ambient Gradients -->
            <div
                class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-white to-transparent pointer-events-none"
            >
            </div>
        </div>

        <!-- Content Flow -->
        <div class="relative z-10 pt-32 px-4 max-w-7xl mx-auto">
            <!-- Hero -->
            <div class="text-center mb-16 space-y-8">
                <div
                    class="inline-flex items-center justify-center gap-3 px-5 py-2.5 rounded-full bg-white/60 backdrop-blur-md border border-[#4e7cce]/30 shadow-sm mb-4"
                >
                    <span class="relative flex h-2.5 w-2.5">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4e7cce] opacity-30"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#4e7cce]"
                        ></span>
                    </span>
                    <span
                        class="text-xs font-bold text-[#4e7cce] uppercase tracking-[0.2em]"
                    >
                        Actualidad
                    </span>
                </div>

                <GradientText
                    text="Noticias ILSA"
                    size="text-5xl md:text-8xl text-center"
                    weight="font-black"
                    from="var(--ilsa-blue)"
                    to="var(--ilsa-blue-dark)"
                    class="justify-center block drop-shadow-sm tracking-tight pb-4"
                />

                <p
                    class="text-lg md:text-2xl text-slate-600 max-w-3xl mx-auto text-balance leading-relaxed font-light"
                >
                    Entérate de las últimas <span
                        class="text-[var(--ilsa-blue)] font-medium"
                        >novedades</span
                    >, comunicados y acciones del Instituto.
                </p>
            </div>

            <WPLoader type="card">
                <div class="container mx-auto px-4 pb-20">
                    {/* Top Pagination */}
                    {
                        totalPages > 1 && (
                            <Pagination
                                totalPages={totalPages}
                                gridId={gridId}
                                cardClass={cardClass}
                                postsPerPage={postsPerPage}
                            />
                        )
                    }

                    {
                        allNews.length > 0 ? (
                            <div
                                id={gridId}
                                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center perspective-1000"
                            >
                                {allNews.map((post, index) => (
                                    <div
                                        class={`${cardClass} ${index >= postsPerPage ? "hidden" : "flex"} w-full justify-center transform transition-transform duration-500 hover:-translate-y-2 group`}
                                    >
                                        <AuthorCard
                                            title={post.title}
                                            author={
                                                post.author?.node?.name ||
                                                "ILSA"
                                            }
                                            authorImage=""
                                            date={new Date(
                                                post.date,
                                            ).toLocaleDateString("es-CO", {
                                                day: "numeric",
                                                month: "short",
                                                year: "numeric",
                                            })}
                                            image={
                                                post.featuredImage?.node
                                                    ?.sourceUrl || ""
                                            }
                                            uri={post.uri}
                                        />
                                    </div>
                                ))}
                            </div>
                        ) : (
                            <div class="text-center py-20 bg-slate-50 rounded-2xl border border-slate-100 shadow-sm">
                                <p class="text-xl text-slate-500 font-medium">
                                    No hay noticias publicadas en este momento.
                                </p>
                            </div>
                        )
                    }

                    {/* Bottom Pagination */}
                    {
                        totalPages > 1 && (
                            <div class="mt-12">
                                <Pagination
                                    totalPages={totalPages}
                                    gridId={gridId}
                                    cardClass={cardClass}
                                    postsPerPage={postsPerPage}
                                />
                            </div>
                        )
                    }
                </div>
            </WPLoader>
        </div>
    </div>
</Layout>
