---
import Layout from "../../layouts/Layout.astro";
import AccordionItem from "../../components/atoms/AccordionItem.astro";
import DirectorCard from "../../components/molecules/DirectorCard.astro";
import TeamModal from "../../components/molecules/TeamModal.astro";
import ColombiaMap from "../../components/organisms/ColombiaMap.astro";
import Breadcrumbs from "../../components/atoms/Breadcrumbs.astro";
import Button from "../../components/Button.astro";
import GradientText from "../../components/atoms/GradientText.astro";
import SmartImage from "../../components/atoms/SmartImage.astro";
import { wpQuery } from "../../lib/wp";
import { teamData, boardData, assemblyData } from "../../lib/team";
import type { SeoData } from "../../lib/seo";

const heroImages = [
    "/images/gallery/Nosotros (5).webp",
    "/images/gallery/Nosotros (6).webp",
    "/images/gallery/Nosotros (7).webp",
    "/images/gallery/Nosotros (12).webp",
    "/images/gallery/Nosotros (14).webp",
];

const geoImages = [
    "/images/gallery/HomeGalery (1).webp",
    "/images/gallery/Nosotros (1).webp",
    "/images/gallery/Nosotros (8).webp",
    "/images/gallery/Nosotros (15).webp",
];

const missionImages = [
    "/images/gallery/HomeGalery (2).webp",
    "/images/gallery/Nosotros (2).webp",
    "/images/gallery/Nosotros (9).webp",
    "/images/gallery/HomeGalery (6).webp",
];

const visionImages = [
    "/images/gallery/HomeGalery (3).webp",
    "/images/gallery/Nosotros (3).webp",
    "/images/gallery/Nosotros (10).webp",
    "/images/gallery/Nosotros (13).webp",
];

const camposImages = [
    "/images/gallery/HomeGalery (4).webp",
    "/images/gallery/HomeGalery (5).webp",
    "/images/gallery/Nosotros (4).webp",
    "/images/gallery/Nosotros (11).webp",
];

export const prerender = true;

const breadcrumbItems = [{ label: "Nosotros", href: "/nosotros" }];

// Fetch SEO Data specifically for this page
const data = await wpQuery({
    query: `
    query GetNosotrosSEO {
      page(id: "/nosotros", idType: URI) {
        seo {
          title
          metaDesc
          canonical
          opengraphTitle
          opengraphDescription
          opengraphImage {
            sourceUrl
          }
          twitterTitle
          twitterDescription
          twitterImage {
             sourceUrl
          }
        }
      }
    }
  `,
});

const seoData: SeoData = data?.page?.seo;
---

<Layout seo={seoData} breadcrumbs={breadcrumbItems}>
    <div
        class="relative min-h-screen text-[#3d3d47] overflow-hidden overflow-x-hidden font-sans"
    >
        <!-- Global Atmosphere Gradients (Cool & Clean) -->
        <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-0">
            <!-- Enhanced Blue/Coolness -->
            <div
                class="absolute top-[-20%] right-[-10%] w-[50%] h-[50%] bg-[#4e7cce]/5 rounded-full blur-[120px]"
            >
            </div>
            <div
                class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#4e7cce]/5 rounded-full blur-[120px]"
            >
            </div>
        </div>

        <div class="relative z-10 pt-8 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
            <!-- HERO SECTION -->
            <section
                id="historia"
                class="mb-24 flex flex-col items-center text-center max-w-5xl mx-auto scroll-mt-32"
            >
                <!-- Badge -->
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#4e7cce]/20 shadow-sm mb-8"
                >
                    <span class="relative flex h-3 w-3">
                        <span
                            class="motion-safe:animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4e7cce] opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-3 w-3 bg-[#4e7cce]"
                        ></span>
                    </span>
                    <span
                        class="text-xs md:text-sm font-bold text-[#4e7cce] uppercase tracking-widest"
                    >
                        Fundado en 1978
                    </span>
                </div>

                <!-- Headline -->
                <h1
                    class="text-5xl md:text-6xl lg:text-7xl font-bold text-center text-[#3d3d47] mb-8 tracking-tight leading-[1.1] text-balance"
                >
                    Justicia Social y <br class="hidden md:block" />
                    <span class="text-[#4e7cce]">Derecho Alternativo</span>
                </h1>

                <!-- Lead -->
                <p
                    class="text-md md:text-lg text-[#3d3d47]/80 max-w-3xl mx-auto leading-relaxed mb-12 text-pretty"
                >
                    Organización no gubernamental creada bajo la convicción de
                    que el derecho puede y debe ser una herramienta para
                    impulsar transformaciones sociales y afianzar la justicia en
                    América Latina y el Caribe.
                </p>

                <!-- Hero Image -->
                <auto-slider
                    class="relative block w-full h-[400px] md:h-[500px] mb-16 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-blue-900/10 group"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[#183069]/60 to-[#4e7cce]/20 mix-blend-multiply z-10 pointer-events-none"
                    >
                    </div>
                    {
                        heroImages.map((src, index) => (
                            <img
                                src={src}
                                alt="Territorio y Naturaleza"
                                width="1200"
                                height="500"
                                class={`absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-all duration-1000 ${index === 0 ? "opacity-100" : "opacity-0"}`}
                                data-slider-image
                                fetchpriority={index === 0 ? "high" : "auto"}
                                loading={index === 0 ? "eager" : "lazy"}
                            />
                        ))
                    }
                </auto-slider>

                <!-- Feature Grid -->
                <div class="grid md:grid-cols-3 gap-8 w-full text-left">
                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#4e7cce]/10 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-blue-50 text-[#4e7cce] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Trayectoria Regional
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Con domicilio principal en Bogotá y un profundo
                            arraigo en América Latina y el Caribe, consolidamos
                            una experiencia histórica en investigación
                            sociopolítica.
                        </p>
                    </div>

                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#5e3b69]/10 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-purple-50 text-[#5e3b69] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Servicio Jurídico Crítico
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Desplegamos una praxis emancipatoria mediante
                            labores pedagógicas y el acompañamiento organizativo
                            a sectores populares.
                        </p>
                    </div>

                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#e9b384]/20 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-orange-50 text-[#e9b384] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Ecología de Saberes
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Articulamos las ciencias sociales y diversas áreas
                            del saber para abordar de manera inter, multi y
                            transdisciplinar los fenómenos sociales complejos.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Divider -->
            <div
                class="w-full h-px bg-gradient-to-r from-transparent via-[#3d3d47]/10 to-transparent mb-24"
            >
            </div>

            <!-- HISTORIA INSTITUCIONAL VERBATIM -->
            <section
                class="mb-24 max-w-7xl mx-auto px-6 lg:px-8 scroll-mt-32 relative"
                id="nuestra-historia"
            >
                <!-- Decorative background glow -->
                <div
                    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-tr from-[#4e7cce]/5 to-[#5e3b69]/5 rounded-full blur-[100px] pointer-events-none -z-10"
                >
                </div>

                <div class="text-center mb-16">
                    <p
                        class="text-[#4e7cce] font-bold text-sm tracking-widest uppercase mb-2"
                    >
                        Memoria y Trayectoria
                    </p>
                    <h2
                        class="text-4xl text-center md:text-5xl font-bold text-[#3d3d47] mb-6"
                    >
                        Historia Institucional
                    </h2>
                    <div
                        class="w-24 h-1 bg-gradient-to-r from-[#4e7cce] to-[#5e3b69] mx-auto rounded-full"
                    >
                    </div>
                </div>

                <div class="space-y-12 lg:space-y-16 relative z-10">
                    <!-- BLOQUE 1: ORIGENES -->
                    <div
                        class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16"
                    >
                        <div
                            class="w-full lg:w-5/12 shrink-0 order-2 lg:order-1"
                        >
                            <!-- Fotografía Orígenes 1978 -->
                            <div
                                class="w-full aspect-[4/3] bg-white/30 backdrop-blur-2xl border border-white/50 rounded-[2.5rem] shadow-xl shadow-[#4e7cce]/5 relative overflow-hidden group"
                            >
                                <div
                                    class="absolute inset-0 bg-gradient-to-br from-[#4e7cce]/20 to-transparent mix-blend-multiply z-10 pointer-events-none opacity-40 group-hover:opacity-10 transition-opacity duration-500"
                                >
                                </div>
                                <SmartImage 
                                    src="/images/multimedia-galeria/visita-chita-julio/visita-chita-julio-34.webp" 
                                    alt="Orígenes de ILSA" 
                                    class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000"
                                />
                            </div>
                        </div>
                        <div class="w-full lg:w-7/12 order-1 lg:order-2">
                            <div class="inline-flex items-center gap-4 mb-5">
                                <span
                                    class="flex items-center justify-center w-12 h-12 rounded-2xl bg-[#4e7cce]/10 text-[#4e7cce] font-bold text-xl border border-[#4e7cce]/20 shadow-sm"
                                    >01</span
                                >
                                <h3 class="text-2xl font-bold text-[#3d3d47]">
                                    Surgimiento y Fundamentos
                                </h3>
                            </div>
                            <div
                                class="p-6 md:p-8 rounded-[2rem] bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 hover:bg-white/60 transition-colors duration-500 relative"
                            >
                                <div
                                    class="absolute top-0 left-8 w-12 h-1 bg-[#4e7cce] rounded-b-full"
                                >
                                </div>
                                <p
                                    class="text-[#3d3d47]/80 text-base leading-relaxed text-pretty"
                                >
                                    El Instituto Latinoamericano para una
                                    Sociedad y un Derecho Alternativos (ILSA) es
                                    una organización no gubernamental creada en
                                    1978 bajo el auspicio del Comité Jurídico
                                    Interamericano (IJC), principal órgano
                                    jurídico de la Organización de Estados
                                    Americanos (OEA), a partir de la convicción
                                    de que el derecho puede y debe ser una
                                    herramienta para impulsar transformaciones
                                    sociales y ampliar el acceso a la justicia
                                    para los sectores populares en América
                                    Latina y el Caribe. Su surgimiento estuvo
                                    marcado por el encuentro entre corrientes
                                    críticas del movimiento Derecho y Desarrollo
                                    y diversas experiencias latinoamericanas de
                                    asistencia jurídica popular.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- BLOQUE 2: CONSOLIDACION -->
                    <div
                        class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16"
                    >
                        <div class="w-full lg:w-7/12">
                            <div class="inline-flex items-center gap-4 mb-5">
                                <span
                                    class="flex items-center justify-center w-12 h-12 rounded-2xl bg-[#5e3b69]/10 text-[#5e3b69] font-bold text-xl border border-[#5e3b69]/20 shadow-sm"
                                    >02</span
                                >
                                <h3 class="text-2xl font-bold text-[#3d3d47]">
                                    Consolidación Institucional
                                </h3>
                            </div>
                            <div
                                class="p-6 md:p-8 rounded-[2rem] bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 hover:bg-white/60 transition-colors duration-500 relative"
                            >
                                <div
                                    class="absolute top-0 left-8 w-12 h-1 bg-[#5e3b69] rounded-b-full"
                                >
                                </div>
                                <p
                                    class="text-[#3d3d47]/80 text-base leading-relaxed text-pretty"
                                >
                                    Durante la década de 1980, ILSA profundizó
                                    un desplazamiento hacia enfoques como el uso
                                    alternativo del derecho, los servicios
                                    legales innovadores y el servicio jurídico
                                    crítico, buscando romper con concepciones
                                    tradicionales de la práctica jurídica. En
                                    1985 obtuvo personería jurídica en Colombia
                                    y estableció su sede principal en Bogotá,
                                    manteniendo su proyección regional.
                                </p>
                            </div>
                        </div>
                        <div class="w-full lg:w-5/12 shrink-0">
                            <!-- Fotografía Consolidación -->
                            <div
                                class="w-full aspect-[4/3] bg-white/30 backdrop-blur-2xl border border-white/50 rounded-[2.5rem] shadow-xl shadow-[#5e3b69]/5 relative overflow-hidden group"
                            >
                                <div
                                    class="absolute inset-0 bg-gradient-to-bl from-[#5e3b69]/20 to-transparent mix-blend-multiply z-10 pointer-events-none opacity-40 group-hover:opacity-10 transition-opacity duration-500"
                                >
                                </div>
                                <SmartImage 
                                    src="/images/multimedia-galeria/mercado-campesino-sep-2005/mercado-campesino-sep-2005-1.webp" 
                                    alt="Consolidación Institucional" 
                                    class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000"
                                />
                            </div>
                        </div>
                    </div>

                    <!-- BLOQUE 3: PRACTICA CRITICA -->
                    <div
                        class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16"
                    >
                        <div
                            class="w-full lg:w-5/12 shrink-0 order-2 lg:order-1"
                        >
                            <!-- Fotografía de Territorio -->
                            <div
                                class="w-full aspect-[4/3] bg-white/30 backdrop-blur-2xl border border-white/50 rounded-[2.5rem] shadow-xl shadow-[#e9b384]/5 relative overflow-hidden group"
                            >
                                <div
                                    class="absolute inset-0 bg-gradient-to-tr from-[#e9b384]/20 to-transparent mix-blend-multiply z-10 pointer-events-none opacity-40 group-hover:opacity-10 transition-opacity duration-500"
                                >
                                </div>
                                <SmartImage 
                                    src="/images/evento-cartagena/evento-cartagena (18).jpg" 
                                    alt="Práctica Crítica y Despliegue en Territorio" 
                                    class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000"
                                />
                            </div>
                        </div>
                        <div class="w-full lg:w-7/12 order-1 lg:order-2">
                            <div class="inline-flex items-center gap-4 mb-5">
                                <span
                                    class="flex items-center justify-center w-12 h-12 rounded-2xl bg-[#e9b384]/20 text-[#e9b384] font-bold text-xl border border-[#e9b384]/30 shadow-sm"
                                    >03</span
                                >
                                <h3 class="text-2xl font-bold text-[#3d3d47]">
                                    Práctica Crítica y Despliegue
                                </h3>
                            </div>
                            <div
                                class="p-6 md:p-8 rounded-[2rem] bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 hover:bg-white/60 transition-colors duration-500 relative"
                            >
                                <div
                                    class="absolute top-0 left-8 w-12 h-1 bg-[#e9b384] rounded-b-full"
                                >
                                </div>
                                <p
                                    class="text-[#3d3d47]/80 text-base leading-relaxed text-pretty"
                                >
                                    Desde entonces, ILSA ha promovido una
                                    práctica crítica del derecho y una
                                    concepción integral de los derechos humanos
                                    mediante labores pedagógicas, acompañamiento
                                    jurídico y fortalecimiento organizativo
                                    junto a asociaciones campesinas, pueblos
                                    indígenas, comunidades negras, procesos de
                                    mujeres, víctimas del conflicto y población
                                    firmante de paz, entre otros sectores
                                    sociales. Su trabajo se ha desplegado en
                                    distintas regiones de Colombia —como el
                                    Ariari, la costa Pacífica caucana, el páramo
                                    de Pisba, el Urabá antioqueño, los Montes de
                                    María y la Amazonia— y, a nivel regional, a
                                    través de redes y plataformas como Consejo
                                    Latinoamericano de Ciencias Sociales y la
                                    Comunidad Latinoamericana de Empoderamiento
                                    Jurídico, desde donde impulsa iniciativas
                                    sobre acceso a la justicia y fortalecimiento
                                    de agendas jurídicas emancipadoras en
                                    América Latina.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- BLOQUE 4: CAMPOS DE ACCION -->
                    <div
                        class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16"
                    >
                        <div class="w-full">
                            <div class="inline-flex items-center gap-4 mb-5">
                                <span
                                    class="flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-200 text-slate-600 font-bold text-xl border border-slate-300 shadow-sm"
                                    >04</span
                                >
                                <h3 class="text-2xl font-bold text-[#3d3d47]">
                                    Plan Estratégico 2025-2027
                                </h3>
                            </div>
                            <div
                                class="p-6 md:p-8 rounded-[2rem] bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 hover:bg-white/60 transition-colors duration-500 relative"
                            >
                                <div
                                    class="absolute top-0 left-8 w-12 h-1 bg-slate-400 rounded-b-full"
                                >
                                </div>
                                <p
                                    class="text-[#3d3d47]/80 text-base leading-relaxed text-pretty"
                                >
                                    ILSA definió para el periodo 2025-2027 los
                                    siguientes cuatro campos de acción:
                                    Conflicto interno y política de paz:
                                    derechos de las víctimas, acuerdos y
                                    justicia transicional; Producción del
                                    territorio y conflictividades.
                                    Territorialidades del capital y
                                    alternativas; Democracias contemporáneas,
                                    luchas sociales y derechos humanos; y
                                    Género, derechos de las mujeres y
                                    diversidades; los cuales adelanta a través
                                    de acciones de (i) servicio legal y asesoría
                                    sociojurídica; (ii) advocacy e incidencia
                                    política; (iii) ecología de saberes,
                                    educación jurídica popular y empoderamiento
                                    legal; (iv) investigación y producción de
                                    conocimiento; (v) alianzas estratégicas y
                                    trabajo en red; (vi) comunicaciones, opinión
                                    pública y publicaciones.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- GEO PRESENCE -->
            <section class="max-w-7xl mx-auto mb-24 text-center">
                <h2 class="text-3xl font-bold text-[#3d3d47] mb-8 text-center">
                    Presencia Geográfica
                </h2>

                <div class="flex flex-col items-center gap-8">
                    <!-- Mapa + texto (centrado, 2/3 del ancho) -->
                    <div class="w-full md:w-2/3 flex flex-col gap-4">
                        <ColombiaMap />
                        <p
                            class="text-[#3d3d47]/70 italic text-sm leading-relaxed"
                        >
                            Despliegue de trabajo situado y adaptado
                            culturalmente en el Ariari (Meta), Costa Pacífica
                            (Cauca), Páramo de Pisba (Boyacá), Urabá
                            (Antioquia), Provincia de Vélez (Santander), Laguna
                            de La Cocha (Nariño), Trapecio Amazónico, Montes de
                            María y el Archipiélago.
                        </p>
                    </div>

                    <!-- Carrusel debajo, ancho completo -->
                    <auto-slider
                        class="relative block w-full h-[280px] md:h-[350px] rounded-3xl overflow-hidden shadow-lg border border-white/50 group"
                    >
                        <div
                            class="absolute inset-0 bg-[#4e7cce]/30 z-10 mix-blend-multiply pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute inset-0 opacity-80 group-hover:opacity-100 transition-opacity duration-500"
                        >
                            {
                                geoImages.map((src, index) => (
                                    <img
                                        src={src}
                                        alt="Ubicación Geográfica ILSA"
                                        width="1200"
                                        height="500"
                                        class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${index === 0 ? "opacity-100" : "opacity-0"}`}
                                        data-slider-image
                                        loading="lazy"
                                    />
                                ))
                            }
                        </div>
                    </auto-slider>
                </div>
            </section>

