---
import Layout from "../../layouts/Layout.astro";
import AccordionItem from "../../components/atoms/AccordionItem.astro";
import DirectorCard from "../../components/molecules/DirectorCard.astro";
import TeamModal from "../../components/molecules/TeamModal.astro";
import ColombiaMap from "../../components/organisms/ColombiaMap.astro";
import Breadcrumbs from "../../components/atoms/Breadcrumbs.astro";
import Button from "../../components/Button.astro";
import GradientText from "../../components/atoms/GradientText.astro";
import { wpQuery } from "../../lib/wp";
import { teamData, boardData, assemblyData } from "../../lib/team";
import type { SeoData } from "../../lib/seo";

const heroImages = [
    "/images/gallery/Nosotros (5).webp",
    "/images/gallery/Nosotros (6).webp",
    "/images/gallery/Nosotros (7).webp",
    "/images/gallery/Nosotros (12).webp",
    "/images/gallery/Nosotros (14).webp"
];

const geoImages = [
    "/images/gallery/HomeGalery (1).webp",
    "/images/gallery/Nosotros (1).webp",
    "/images/gallery/Nosotros (8).webp",
    "/images/gallery/Nosotros (15).webp"
];

const missionImages = [
    "/images/gallery/HomeGalery (2).webp",
    "/images/gallery/Nosotros (2).webp",
    "/images/gallery/Nosotros (9).webp",
    "/images/gallery/HomeGalery (6).webp"
];

const visionImages = [
    "/images/gallery/HomeGalery (3).webp",
    "/images/gallery/Nosotros (3).webp",
    "/images/gallery/Nosotros (10).webp",
    "/images/gallery/Nosotros (13).webp"
];

const camposImages = [
    "/images/gallery/HomeGalery (4).webp",
    "/images/gallery/HomeGalery (5).webp",
    "/images/gallery/Nosotros (4).webp",
    "/images/gallery/Nosotros (11).webp"
];

export const prerender = true;

const breadcrumbItems = [{ label: "Nosotros", href: "/nosotros" }];

// Fetch SEO Data specifically for this page
const data = await wpQuery({
    query: `
    query GetNosotrosSEO {
      page(id: "/nosotros", idType: URI) {
        seo {
          title
          metaDesc
          canonical
          opengraphTitle
          opengraphDescription
          opengraphImage {
            sourceUrl
          }
          twitterTitle
          twitterDescription
          twitterImage {
             sourceUrl
          }
        }
      }
    }
  `,
});

const seoData: SeoData = data?.page?.seo;
---

<Layout seo={seoData} breadcrumbs={breadcrumbItems}>
    <div class="relative min-h-screen text-[#3d3d47] overflow-hidden overflow-x-hidden font-sans">
        <!-- Global Atmosphere Gradients (Cool & Clean) -->
        <div class="fixed top-0 left-0 w-full h-full pointer-events-none z-0">
            <!-- Enhanced Blue/Coolness -->
            <div
                class="absolute top-[-20%] right-[-10%] w-[50%] h-[50%] bg-[#4e7cce]/5 rounded-full blur-[120px]"
            >
            </div>
            <div
                class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#4e7cce]/5 rounded-full blur-[120px]"
            >
            </div>
        </div>

        <div class="relative z-10 pt-8 pb-24 px-6 md:px-12 max-w-7xl mx-auto">
            <!-- HERO SECTION -->
            <section
                id="historia"
                class="mb-24 flex flex-col items-center text-center max-w-5xl mx-auto scroll-mt-32"
            >
                <!-- Badge -->
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-[#4e7cce]/20 shadow-sm mb-8"
                >
                    <span class="relative flex h-3 w-3">
                        <span
                            class="motion-safe:animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4e7cce] opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-3 w-3 bg-[#4e7cce]"
                        ></span>
                    </span>
                    <span
                        class="text-xs md:text-sm font-bold text-[#4e7cce] uppercase tracking-widest"
                    >
                        Fundado en 1978
                    </span>
                </div>

                <!-- Headline -->
                <h1
                    class="text-5xl md:text-6xl lg:text-7xl font-bold text-center text-[#3d3d47] mb-8 tracking-tight leading-[1.1] text-balance"
                >
                    Justicia Social y <br class="hidden md:block" />
                    <span class="text-[#4e7cce]">Derecho Alternativo</span>
                </h1>

                <!-- Lead -->
                <p
                    class="text-xl md:text-2xl text-[#3d3d47]/80 max-w-3xl mx-auto leading-relaxed mb-12 text-pretty"
                >
                    Promovemos una visión crítica del derecho y la
                    transformación social en América Latina, reconociendo la
                    naturaleza como sujeto de derechos.
                </p>

                <!-- Hero Image -->
                <auto-slider
                    class="relative block w-full h-[400px] md:h-[500px] mb-16 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-blue-900/10 group"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[#183069]/60 to-[#4e7cce]/20 mix-blend-multiply z-10 pointer-events-none"
                    >
                    </div>
                    {heroImages.map((src, index) => (
                        <img
                            src={src}
                            alt="Territorio y Naturaleza"
                            width="1200"
                            height="500"
                            class={`absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-all duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                            data-slider-image
                            fetchpriority={index === 0 ? 'high' : 'auto'}
                            loading={index === 0 ? 'eager' : 'lazy'}
                        />
                    ))}
                </auto-slider>

                <!-- Feature Grid -->
                <div class="grid md:grid-cols-3 gap-8 w-full text-left">
                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#4e7cce]/10 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-blue-50 text-[#4e7cce] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Trayectoria Regional
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Desde Bogotá para toda América Latina, consolidando
                            una experiencia histórica en investigación y acción
                            política.
                        </p>
                    </div>

                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#5e3b69]/10 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-purple-50 text-[#5e3b69] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Praxis Emancipatoria
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Trabajamos junto a movimientos sociales,
                            organizaciones de mujeres, campesinas e indígenas.
                        </p>
                    </div>

                    <div
                        class="p-8 rounded-2xl bg-white border border-slate-100 shadow-lg shadow-slate-200/50 hover:shadow-xl hover:shadow-[#e9b384]/20 transition-all duration-300 group"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-orange-50 text-[#e9b384] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                                ></path></svg
                            >
                        </div>
                        <h3 class="text-xl font-bold text-[#3d3d47] mb-3">
                            Enfoque Integral
                        </h3>
                        <p class="text-[#3d3d47]/70 text-sm leading-relaxed">
                            Derechos económicos, socioambientales y de la
                            naturaleza, con enfoques diferenciales.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Divider -->
            <div
                class="w-full h-px bg-gradient-to-r from-transparent via-[#3d3d47]/10 to-transparent mb-24"
            >
            </div>

            <!-- GEO PRESENCE -->
            <section class="max-w-7xl mx-auto mb-24 text-center">
                <h2 class="text-3xl font-bold text-[#3d3d47] mb-8 text-center">
                    Presencia Geográfica
                </h2>

                <div class="flex flex-col items-center gap-8">
                    <!-- Mapa + texto (centrado, 2/3 del ancho) -->
                    <div class="w-full md:w-2/3 flex flex-col gap-4">
                        <ColombiaMap />
                        <p class="text-[#3d3d47]/70 italic text-sm leading-relaxed">
                            Meta (Ariari) · Cauca (Costa Pacífica) · Boyacá (Páramo de Pisba) ·
                            Antioquia (Urabá) · Santander (Provincia de Vélez) · Nariño (Laguna de La Cocha) ·
                            Amazonas (Leticia) · Bolívar y Sucre (Montes de María) · San Andrés y Providencia.
                        </p>
                    </div>

                    <!-- Carrusel debajo, ancho completo -->
                    <auto-slider
                        class="relative block w-full h-[280px] md:h-[350px] rounded-3xl overflow-hidden shadow-lg border border-white/50 group"
                    >
                        <div
                            class="absolute inset-0 bg-[#4e7cce]/30 z-10 mix-blend-multiply pointer-events-none"
                        >
                        </div>
                        <div class="absolute inset-0 opacity-80 group-hover:opacity-100 transition-opacity duration-500">
                            {geoImages.map((src, index) => (
                                <img
                                    src={src}
                                    alt="Ubicación Geográfica ILSA"
                                    width="1200"
                                    height="500"
                                    class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                                    data-slider-image
                                    loading="lazy"
                                />
                            ))}
                        </div>
                    </auto-slider>
                </div>
            </section>

            <!-- MISSION / VISION -->
            <section class="grid md:grid-cols-2 gap-12 mb-32 items-center">
                <!-- Mission Content -->
                <div class="order-2 md:order-1">
                    <div class="inline-flex items-center gap-2 mb-4">
                        <span class="w-2 h-8 bg-[#4e7cce] rounded-full"></span>
                        <h2
                            class="text-4xl font-bold text-[#3d3d47]"
                            id="mision"
                        >
                            Misión
                        </h2>
                    </div>
                    <p
                        class="text-lg text-[#3d3d47] leading-relaxed mb-6 font-medium"
                    >
                        Transformación de relaciones sociales en perspectiva
                        emancipadora.
                    </p>
                    <div
                        class="space-y-4 text-[#3d3d47]/80 leading-relaxed text-pretty"
                    >
                        <p>
                            ILSA contribuye con un enfoque alternativo y crítico
                            del derecho. Articula pensamiento jurídico crítico,
                            derecho nacido de las prácticas sociales y formación
                            crítica.
                        </p>
                        <p>
                            Promueve sujetos democráticos capaces de construir
                            sociedad con justicia social, en armonía con la
                            naturaleza.
                        </p>
                    </div>
                </div>

                <!-- Mission Image -->
                <auto-slider
                    class="order-1 md:order-2 block w-full h-[450px] rounded-[2.5rem] overflow-hidden shadow-xl shadow-blue-900/10 relative group"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-tr from-[#4e7cce]/40 to-[#4e7cce]/10 mix-blend-multiply z-10 pointer-events-none"
                    >
                    </div>
                    {missionImages.map((src, index) => (
                        <img
                            src={src}
                            alt="Trabajo comunitario de ILSA con movimientos sociales"
                            width="800"
                            height="450"
                            class={`absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-all duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                            data-slider-image
                            loading="lazy"
                        />
                    ))}
                </auto-slider>

                <!-- Vision Image -->
                <auto-slider
                    class="block w-full h-[450px] rounded-[2.5rem] overflow-hidden shadow-xl shadow-purple-900/10 relative group"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-bl from-[#5e3b69]/40 to-[#4e7cce]/20 mix-blend-multiply z-10 pointer-events-none"
                    >
                    </div>
                    {visionImages.map((src, index) => (
                        <img
                            src={src}
                            alt="Territorios y comunidades que defiende ILSA"
                            width="800"
                            height="450"
                            class={`absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-all duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                            data-slider-image
                            loading="lazy"
                        />
                    ))}
                </auto-slider>

                <!-- Vision Content -->
                <div>
                    <div class="inline-flex items-center gap-2 mb-4">
                        <span class="w-2 h-8 bg-[#5e3b69] rounded-full"></span>
                        <h2
                            class="text-4xl font-bold text-[#3d3d47]"
                            id="vision"
                        >
                            Visión
                        </h2>
                    </div>
                    <p
                        class="text-lg text-[#3d3d47] leading-relaxed mb-6 font-medium"
                    >
                        Horizonte político de defensa y promoción integral.
                    </p>
                    <div
                        class="space-y-4 text-[#3d3d47]/80 leading-relaxed text-pretty"
                    >
                        <p>
                            ILSA será referente en la Región y Colombia por sus
                            contribuciones teóricas y prácticas desde el derecho
                            alternativo.
                        </p>
                        <p>
                            Reconocida por su compromiso con el campesinado,
                            mujeres, comunidades afro y pueblos indígenas en
                            defensa de los territorios y distribución equitativa
                            de la tierra.
                        </p>
                    </div>
                </div>
            </section>

            <!-- CAMPOS DE ACCION -->
            <section class="mb-32 max-w-7xl mx-auto">
                <div
                    class="flex flex-col md:flex-row items-center gap-12 lg:gap-16 p-6 md:p-12 rounded-[2.5rem] bg-white/50 backdrop-blur-3xl border border-white/60 shadow-xl shadow-slate-200/50"
                >
                    <div class="w-full md:w-5/12 shrink-0">
                        <auto-slider
                            class="relative block group rounded-2xl overflow-hidden shadow-2xl shadow-blue-900/10 aspect-square md:aspect-[4/5]"
                        >
                            <div
                                class="absolute inset-0 bg-[#4e7cce]/30 mix-blend-multiply group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"
                            >
                            </div>
                            {camposImages.map((src, index) => (
                                <img
                                    src={src}
                                    alt="Campos de acción e intervención territorial de ILSA"
                                    width="800"
                                    height="900"
                                    class={`absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-all duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                                    data-slider-image
                                    loading="lazy"
                                />
                            ))}
                        </auto-slider>
                    </div>

                    <!-- Right: Content -->
                    <div class="w-full md:w-7/12">
                        <p
                            class="text-[#4e7cce] font-bold text-sm tracking-widest uppercase mb-2"
                        >
                            Nuestros Ejes
                        </p>
                        <h2
                            class="text-3xl md:text-4xl font-bold text-[#3d3d47] mb-6"
                        >
                            Campos de Acción
                        </h2>
                        <p
                            class="text-[#3d3d47]/70 text-base leading-relaxed mb-8"
                        >
                            Estructuramos nuestras intervenciones en ejes
                            fundamentales para abordar la complejidad de los
                            derechos humanos y la justicia social en la región.
                        </p>

                        <!-- Accordion Items -->
                        <div class="space-y-3">
                            <AccordionItem
                                variant="light"
                                title="Conflicto interno y construcción de paz"
                                isOpen={true}
                            >
                                <p
                                    class="mb-4 text-[#3d3d47] text-sm leading-relaxed"
                                >
                                    <strong>Enfoque:</strong> Derechos humanos, políticas
                                    de seguridad, derecho transicional y garantías
                                    de no repetición.
                                </p>
                            </AccordionItem>
                            <AccordionItem
                                variant="light"
                                title="Producción del territorio y conflictividades"
                            >
                                <p
                                    class="mb-4 text-[#3d3d47] text-sm leading-relaxed"
                                >
                                    <strong>Enfoque:</strong> Resistencias, alternativas
                                    al desarrollo y conflictos socioambientales (territorialidades
                                    del capital).
                                </p>
                            </AccordionItem>
                            <AccordionItem
                                variant="light"
                                title="Perspectivas críticas sobre DDHH"
                            >
                                <p
                                    class="mb-4 text-[#3d3d47] text-sm leading-relaxed"
                                >
                                    <strong>Enfoque:</strong> Políticas públicas inclusivas,
                                    participación incidente y nuevos paradigmas jurídicos.
                                </p>
                            </AccordionItem>
                            <AccordionItem
                                variant="light"
                                title="Género y derechos de las mujeres"
                            >
                                <p
                                    class="mb-4 text-[#3d3d47] text-sm leading-relaxed"
                                >
                                    <strong>Enfoque:</strong> Acceso a la justicia,
                                    economía del cuidado y participación política
                                    de las mujeres.
                                </p>
                            </AccordionItem>
                        </div>
                    </div>
                </div>
            </section>

            <!-- DIRECCION EJECUTIVA SECTION -->
            <section class="max-w-7xl mx-auto mb-24">
                <div class="text-center mb-12">
                    <h2 class="text-4xl font-bold text-center text-[#3d3d47] mb-4 mx-auto" id="direccion-ejecutiva">
                        Dirección Ejecutiva
                    </h2>
                    <div class="w-16 h-1 bg-[#4e7cce] mx-auto rounded-full"></div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
                    {teamData.map((member, index) => (
                        <div
                            class={`interactive-card relative group rounded-[2rem] overflow-hidden shadow-lg hover:shadow-2xl cursor-pointer h-[400px] md:h-[450px] w-full focus-visible:ring-2 focus-visible:ring-[#4e7cce] focus-visible:ring-offset-2 outline-none ${index === 0 ? 'ring-2 ring-white/40 shadow-[#4e7cce]/20' : ''}`}
                            data-team-id={member.id} tabindex="0" role="button"
                        >
                            <img class="h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-110" src={member.image} alt={member.name} width="400" height="450" loading="lazy" />
                            
                            {/* Insignia elegante "Liquid Glass" exclusiva para la Dirección Ejecutiva */}
                            {index === 0 && (
                                <div class="absolute top-4 right-4 z-20 bg-white/20 backdrop-blur-md border border-white/40 rounded-full p-2.5 shadow-lg group-hover:bg-white/30 transition-colors duration-300 pointer-events-none">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="drop-shadow-[0_0_8px_rgba(250,204,21,0.6)]">
                                        <defs>
                                            <linearGradient id="gold-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#FEF08A" />
                                                <stop offset="40%" stop-color="#F59E0B" />
                                                <stop offset="100%" stop-color="#A16207" />
                                            </linearGradient>
                                        </defs>
                                        <polygon fill="url(#gold-grad)" stroke="#FEF08A" stroke-width="1.5" stroke-linejoin="round" points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                    </svg>
                                </div>
                            )}

                            <div class={`absolute inset-0 bg-gradient-to-t opacity-90 transition-opacity duration-300 ${index === 0 ? 'from-[#0b1b42] via-[#102352]/50 to-transparent' : 'from-[#183069] via-[#183069]/40 to-transparent'}`}></div>
                            <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                <p class={`font-bold text-xs tracking-widest uppercase mb-1 opacity-80 group-hover:opacity-100 text-center shrink-0 ${index === 0 ? 'text-[#a1c4ff]' : 'text-[#efefef]'}`}>{member.role}</p>
                                <div class="h-14 md:h-16 flex items-center justify-center w-full mb-2 shrink-0">
                                    <h3 class={`font-bold text-center text-white leading-tight drop-shadow-md ${member.name.length > 20 ? 'text-lg md:text-xl' : 'text-xl md:text-2xl'}`}>{member.name}</h3>
                                </div>
                                <div class="h-0 group-hover:h-auto overflow-hidden transition-all duration-500 opacity-0 group-hover:opacity-100 text-center">
                                    <p class="text-slate-300 text-sm mt-2">{member.bio || ""}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- BOARD SECTION -->
            <section class="max-w-7xl mx-auto mb-24">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-center text-[#3d3d47] mb-4 mx-auto" id="junta-directiva">
                        Junta Directiva de ILSA
                    </h2>
                    <div class="w-16 h-1 bg-[#4e7cce] mx-auto rounded-full"></div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
                    {boardData.map((member, index) => (
                        <div
                            class={`interactive-card relative group rounded-[2rem] overflow-hidden shadow-lg hover:shadow-2xl cursor-pointer h-[400px] md:h-[450px] w-full focus-visible:ring-2 focus-visible:ring-[#4e7cce] focus-visible:ring-offset-2 outline-none ${index === 0 ? 'ring-2 ring-white/40 shadow-[#4e7cce]/20' : ''}`}
                            data-team-id={member.id} tabindex="0" role="button"
                        >
