---
import Layout from "../layouts/Layout.astro";
import GradientText from "../components/atoms/GradientText.astro";
import LiquidContainer from "../components/experimental/LiquidContainer.astro";
import PayPalDonation from "../components/molecules/PayPalDonation";

export const prerender = true;
---

<Layout
    title="Donaciones - ILSA"
    seo={{
        metaDesc:
            "Apoya el trabajo de ILSA en la defensa de los derechos humanos, la investigación crítica y el acceso a la justicia en América Latina.",
    }}
    width="narrow"
>
    <div class="relative text-center py-16 sm:py-24 px-4">
        <h1 class="sr-only">
            Donaciones a ILSA - Instituto Latinoamericano para una Sociedad y un Derecho Alternativos
        </h1>
        <LiquidContainer frosted={true} class="max-w-3xl mx-auto rounded-3xl">
            <div class="p-10 md:p-16">
                <!-- Header -->
                <div class="mb-12">
                    <GradientText
                        as="h2"
                        text="Impulsa la transformación social y el acceso a la justicia"
                        size="text-4xl md:text-5xl text-center"
                        weight="font-black"
                        from="var(--ilsa-blue)"
                        to="#0070ba"
                        class="justify-center mb-6 block w-fit mx-auto pb-2"
                    />
                    <p
                        class="text-center justify-center text-lg text-slate-700 text-balance leading-relaxed max-w-2xl mx-auto"
                    >
                        Al donar a&nbsp;ILSA, financias nuestro trabajo institucional
                        en investigación sociojurídica, incidencia política, educación legal
                        popular y&nbsp;acompañamiento a comunidades en América Latina. 
                        Tu contribución sostiene nuestras iniciativas por la defensa 
                        de los derechos humanos y territoriales.
                    </p>
                </div>

                <!-- PayPal Button Container -->
                <div class="max-w-xl mx-auto">
                    <div
                        class="glass-donation-box rounded-3xl p-8 border border-white/30 bg-white/40 backdrop-blur-xl shadow-xl"
                    >
                        <div class="text-center mb-6">
                            <h3
                                class="text-xl font-bold text-slate-800 mb-2 uppercase tracking-wider text-center"
                            >
                                Realizar donación
                            </h3>
                            <p class="text-sm text-slate-600 text-center">
                                Selecciona o ingresa el monto de tu donación.
                            </p>
                        </div>

                        <!-- PayPal React Island -->
                        <PayPalDonation client:load />
                    </div>

                    <!-- Info Section -->
                    <div class="mt-10 space-y-4 animate-fade-in-up" style="animation-delay: 0.2s; animation-fill-mode: both;">
                        <div
                            class="flex items-start gap-3 p-4 rounded-2xl bg-white/30 border border-white/20 backdrop-blur-sm transition-all duration-300 hover:bg-white/40 hover:-translate-y-1 hover:shadow-lg hover:border-white/40 group/card"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="text-[#0070ba] shrink-0 mt-0.5 transition-transform duration-300 group-hover/card:scale-110 group-hover/card:rotate-3"
                            >
                                <path
                                    d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"
                                ></path>
                            </svg>
                            <div>
                                <p
                                    class="font-semibold text-slate-800 mb-1 text-left"
                                >
                                    Transacción segura
                                </p>
                                <p class="text-sm text-slate-600 text-left">
                                    Tu donación se procesa a través de la infraestructura global de PayPal, garantizando la seguridad y encriptación de tus datos financieros en todo momento.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Badge -->
                    <div
                        class="mt-10 pt-8 border-t border-slate-300/30 flex justify-center gap-2 opacity-70"
                    >
                        <span
                            class="text-xs font-medium uppercase tracking-widest text-slate-500 flex items-center gap-2"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                                ></path>
                            </svg>
                            Powered by PayPal
                        </span>
                    </div>
                </div>
            </div>
        </LiquidContainer>
    </div>

</Layout>

<style>
    .glass-donation-box {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.5) 0%,
            rgba(255, 255, 255, 0.3) 100%
        );
        box-shadow:
            0 8px 32px 0 rgba(0, 112, 186, 0.1),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.5);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
        animation: float 6s ease-in-out infinite, fade-in-up 0.8s ease-out;
    }
    
    .glass-donation-box:hover {
        transform: translateY(-4px);
        box-shadow: 
            0 15px 40px 0 rgba(0, 112, 186, 0.15),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.6);
        animation-play-state: paused;
    }

    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
        100% { transform: translateY(0px); }
    }

    @keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out;
    }

    @keyframes shimmer {
        100% {
            transform: translateX(100%);
        }
    }
</style>

