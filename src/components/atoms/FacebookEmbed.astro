---
interface Props {
    src: string;
    class?: string;
}

const { src, class: className = "" } = Astro.props;
---

<div
    class={`aspect-video w-full overflow-hidden rounded-[2rem] bg-slate-900 shadow-xl border border-white/20 relative group flex justify-center items-center ${className}`}
>
    <iframe
        class="absolute inset-0 w-full h-full border-0 transition-transform duration-500 scale-100 group-hover:scale-[1.02] pointer-events-auto"
        src={src}
        style="border:none;overflow:hidden"
        scrolling="no"
        frameborder="0"
        allowfullscreen="true"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        loading="lazy"
    >
    </iframe>

    <!-- Subtle glass glare overlay -->
    <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-white/0 via-white/5 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
    >
    </div>
</div>
