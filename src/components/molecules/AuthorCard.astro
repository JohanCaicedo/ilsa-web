---
interface Props {
    title: string;
    author: string;
    authorImage: string;
    image: string;
    date: string;
    uri: string;
    width?: number;
    height?: number;
    gradient?: string;
    excerpt?: string;
}

const {
    title,
    author,
    authorImage,
    image,
    date,
    uri,
    width = 400,
    height = 400,
    gradient,
    excerpt,
} = Astro.props;
---

<a
    href={uri}
    class="group relative block w-full max-w-[380px] rounded-2xl glass-panel p-6 transition-transform transition-shadow duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_12px_40px_-8px_var(--glass-shadow)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--ilsa-blue)] focus-visible:ring-offset-2 touch-action-manipulation"
>
    <!-- Accent bar (left edge) -->
    <div
        class="absolute left-0 top-6 bottom-6 w-[3px] rounded-full bg-[var(--ilsa-blue)] opacity-40 group-hover:opacity-100 transition-opacity duration-300"
    >
    </div>

    <!-- Content -->
    <div class="pl-4 flex flex-col gap-4">
        <!-- Author tag -->
        <span
            class="text-[11px] font-bold tracking-[0.15em] text-[var(--ilsa-blue)] uppercase"
        >
            {author}
        </span>

        <!-- Title -->
        <h3
            class="font-sans text-lg font-bold leading-[1.3] text-[var(--ilsa-text-dark)] line-clamp-3 group-hover:text-[var(--ilsa-blue-dark)] transition-colors duration-300"
            style="text-wrap: balance;"
        >
            {title}
        </h3>

        <!-- Excerpt -->
        {
            excerpt && (
                <p class="text-[13px] leading-[1.65] text-[var(--ilsa-text-gray)] font-medium line-clamp-3">
                    {excerpt}
                </p>
            )
        }

        <!-- Footer: Date + Read arrow -->
        <div
            class="flex items-center justify-between pt-2 border-t border-[var(--glass-border)]"
        >
            <time
                class="text-[11px] font-semibold text-[var(--ilsa-text-gray)]/60 tracking-wide uppercase"
            >
                {date}
            </time>

            <div
                class="flex items-center gap-1 text-[var(--ilsa-blue)] opacity-0 translate-x-[-4px] transition-all duration-300 ease-out group-hover:opacity-100 group-hover:translate-x-0"
            >
                <span class="text-[10px] font-bold uppercase tracking-wider"
                    >Leer</span
                >
                <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </div>
        </div>
    </div>
</a>
