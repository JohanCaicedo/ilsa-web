---
// src/components/molecules/GalleryLightbox.astro
---

<gallery-lightbox>
    <div id="custom-gallery-wrapper">
        <slot />
    </div>

    <!-- LIGHTBOX MODAL -->
    <dialog
        id="lightbox"
        class="fixed inset-0 z-[200] m-0 w-[100vw] h-[100vh] max-w-none max-h-none p-0 bg-transparent items-center justify-center border-none backdrop:bg-transparent"
        aria-label="Visor de imagen"
    >
        <!-- Backdrop (Light) -->
        <div
            id="lightbox-backdrop"
            class="absolute inset-0 bg-white/90 backdrop-blur-2xl -z-10"
        >
        </div>

        <!-- Top Bar Controls -->
        <div class="absolute top-0 left-0 right-0 z-20 flex justify-between items-center p-6">
            <!-- Counter -->
            <div
                id="lightbox-counter"
                class="bg-slate-100 backdrop-blur-md text-slate-700 text-sm font-bold px-4 py-2 rounded-full border border-slate-200 shadow-sm transition-opacity"
            >
                1 / X
            </div>
        </div>

        <!-- Prev Button -->
        <button
            id="lightbox-prev"
            type="button"
            class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-slate-100 backdrop-blur-md text-slate-700 rounded-full p-4 transition-all duration-300 hover:scale-110 border border-slate-200 shadow-md"
            aria-label="Foto anterior"
        >
            <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 19l-7-7 7-7"></path></svg
            >
        </button>

        <!-- Next Button -->
        <button
            id="lightbox-next"
            type="button"
            class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-10 bg-white hover:bg-slate-100 backdrop-blur-md text-slate-700 rounded-full p-4 transition-all duration-300 hover:scale-110 border border-slate-200 shadow-md"
            aria-label="Foto siguiente"
        >
            <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"></path></svg
            >
        </button>

        <!-- Image Container -->
        <div
            class="relative z-[1] flex items-center justify-center w-full h-full p-12 md:p-24"
        >
            <img
                id="lightbox-img"
                src=""
                alt=""
                class="max-w-full max-h-full object-contain rounded-2xl shadow-2xl transition-opacity duration-300"
            />
        </div>

        <!-- Bottom Toast (Close) -->
        <div
            class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex items-center shadow-2xl rounded-full overflow-hidden border border-slate-200/80 bg-white/80 backdrop-blur-xl text-slate-800 transition-transform hover:scale-105 duration-300"
        >
            <button
                id="lightbox-close"
                type="button"
                class="flex items-center justify-center hover:bg-slate-200/80 transition-colors px-5 py-4 border-r border-slate-200/80 text-slate-700 cursor-pointer"
                aria-label="Cerrar visor"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path></svg
                >
            </button>
            <div class="px-6 py-4 text-sm font-medium tracking-wide">
                Usa <kbd
                    class="px-2.5 py-1.5 mx-1.5 bg-slate-100 rounded-md font-mono text-xs border border-slate-200 shadow-sm"
                    >Esc</kbd
                > para cerrar
            </div>
        </div>
    </dialog>
</gallery-lightbox>

<style>
    #lightbox[open] {
        display: flex;
    }
    #lightbox-img.switching {
        opacity: 0;
    }
</style>

<script>
    import type { GalleryImage } from "../../lib/galleries";

    class GalleryLightboxElement extends HTMLElement {
        connectedCallback() {
            const lightbox = this.querySelector("#lightbox") as HTMLDialogElement | null;
            const lightboxImg = this.querySelector("#lightbox-img") as HTMLImageElement | null;
            const lightboxCounter = this.querySelector("#lightbox-counter") as HTMLElement | null;
            const closeBtn = this.querySelector("#lightbox-close");
            const prevBtn = this.querySelector("#lightbox-prev");
            const nextBtn = this.querySelector("#lightbox-next");
            const backdrop = this.querySelector("#lightbox-backdrop");
            const wrapper = this.querySelector("#custom-gallery-wrapper");

            if (!lightbox || !lightboxImg || !lightboxCounter) return;

            let currentIndex = 0;
            let dynamicImages: GalleryImage[] = [];

            const isDynamicMode = () => dynamicImages.length > 0;

            const getTotalImages = () => {
                if (isDynamicMode()) return dynamicImages.length;
                if (!wrapper) return 0;
                return wrapper.querySelectorAll(".gallery-thumb").length;
            };

            const getImageSrc = (index: number) => {
                if (isDynamicMode()) return dynamicImages[index]?.src || "";
                if (!wrapper) return "";
                const thumb = wrapper.querySelectorAll(".gallery-thumb")[index];
                const img = thumb?.querySelector("img");
                return img ? img.src : "";
            };

            const getImageAlt = (index: number) => {
                if (isDynamicMode()) return dynamicImages[index]?.alt || "";
                if (!wrapper) return "";
                const thumb = wrapper.querySelectorAll(".gallery-thumb")[index];
                const img = thumb?.querySelector("img");
                return img ? img.alt : "";
            };

            const showImage = (index: number) => {
                const total = getTotalImages();
                if (total === 0) return;
                
                currentIndex = ((index % total) + total) % total;
                lightboxImg.classList.add("switching");
                
                setTimeout(() => {
                    lightboxImg.src = getImageSrc(currentIndex);
                    lightboxImg.alt = getImageAlt(currentIndex);
                    lightboxCounter.textContent = `${currentIndex + 1} / ${total}`;
                    lightboxImg.classList.remove("switching");
                }, 150);
            };

            const open = (index: number, images?: GalleryImage[]) => {
                if (images && Array.isArray(images)) {
                    dynamicImages = images;
                } else {
                    dynamicImages = []; // fallback to wrapper mode if no images provided
                }
                
                const total = getTotalImages();
                if (total === 0) return;

                currentIndex = index;
                lightboxImg.src = getImageSrc(currentIndex);
                lightboxImg.alt = getImageAlt(currentIndex);
                lightboxCounter.textContent = `${currentIndex + 1} / ${total}`;
                
                lightbox.showModal();
                // Previene scroll pero no sobrescribe comportamiento previo (como el del album modal)
                document.documentElement.style.overflow = "hidden";
            };

            const close = () => {
                lightbox.close();
                // Si el body ya estaba hidden por otro modal (ej. AlbumModal), no deberíamos resetearlo.
                // En este caso simple reseteamos a "" que es el default, el CSS :has(dialog[open]) de AlbumModal seguirá activo si ese está abierto.
                document.documentElement.style.overflow = "";
            };

            // Event Listeners for Wrapper mode (Legacy)
            if (wrapper) {
                const thumbs = wrapper.querySelectorAll(".gallery-thumb");
                thumbs.forEach((thumb, idx) => {
                    thumb.addEventListener("click", () => open(idx));
                });
            }

            // Event Listener for Dynamic Mode 
            this._boundOpenLightbox = ((e: CustomEvent<{images: GalleryImage[], startIndex: number}>) => {
                if (e.detail && Array.isArray(e.detail.images)) {
                    open(e.detail.startIndex || 0, e.detail.images);
                }
            }) as EventListener;
            window.addEventListener('open-lightbox', this._boundOpenLightbox);

            closeBtn?.addEventListener("click", close);
            backdrop?.addEventListener("click", close);
            prevBtn?.addEventListener("click", () => showImage(currentIndex - 1));
            nextBtn?.addEventListener("click", () => showImage(currentIndex + 1));

            // Esc key handler specifically scoped to bound checks
            this.handleKeydown = (e: KeyboardEvent) => {
                if (!lightbox.hasAttribute("open")) return;
                
                if (e.key === "Escape") {
                    e.stopPropagation();
                    close();
                }
                if (e.key === "ArrowLeft") showImage(currentIndex - 1);
                if (e.key === "ArrowRight") showImage(currentIndex + 1);
            };

            document.addEventListener("keydown", this.handleKeydown, { capture: true });
        }

        disconnectedCallback() {
            if (this.handleKeydown) {
                document.removeEventListener("keydown", this.handleKeydown, { capture: true });
            }
            if (this._boundOpenLightbox) {
                window.removeEventListener('open-lightbox', this._boundOpenLightbox);
            }
        }

        handleKeydown!: (e: KeyboardEvent) => void;
        _boundOpenLightbox!: EventListener;
    }

    customElements.define("gallery-lightbox", GalleryLightboxElement);
</script>
