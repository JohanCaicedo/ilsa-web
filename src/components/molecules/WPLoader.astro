---
import SkeletonLoader from "../atoms/SkeletonLoader.astro";

interface Props {
    type?: "article" | "card" | "text" | "author-header";
    class?: string;
    minHeight?: string; // Allow overriding min-height
}

const {
    type = "article",
    class: className,
    minHeight = "min-h-[50vh]",
} = Astro.props;
const uniqueId = `wp-loader-${Math.random().toString(36).substr(2, 9)}`;
---

<div
    class={`relative ${minHeight} ${className}`}
    data-wp-loader="true"
    data-loaded="false"
>
    <!-- Skeleton Overlay -->
    <div
        data-loader-skeleton
        class="absolute inset-0 z-10 bg-[var(--ilsa-bg-light)] transition-opacity duration-700 ease-out"
        aria-hidden="true"
    >
        <SkeletonLoader type={type} />
    </div>

    <!-- Real Content (Opacity 0 initially) -->
    <div
        data-loader-content
        class="opacity-0 transition-opacity duration-700 ease-out h-full w-full"
    >
        <slot />
    </div>
</div>

<script>
    // Usar clases en lugar de IDs únicos pesados, y delegación de eventos para View Transitions
    function initLoaders() {
        const loaders = document.querySelectorAll('[data-wp-loader="true"]');

        loaders.forEach((loader) => {
            // Check if already initialized to prevent double-fading
            if (loader.getAttribute("data-loaded") === "true") return;

            const skeleton = loader.querySelector("[data-loader-skeleton]");
            const content = loader.querySelector("[data-loader-content]");

            if (skeleton && content) {
                // Force delay to ensure visual stability and "smoothness", same 1.5s
                setTimeout(() => {
                    requestAnimationFrame(() => {
                        (skeleton as HTMLElement).style.opacity = "0";
                        (content as HTMLElement).style.opacity = "1";
                        loader.setAttribute("data-loaded", "true");

                        // Remove skeleton from DOM flow after transition
                        setTimeout(() => {
                            (skeleton as HTMLElement).style.display = "none";
                        }, 700); // Match transition duration
                    });
                }, 1500);
            }
        });
    }

    // Run on initial load and View Transitions
    document.addEventListener("astro:page-load", initLoaders);
    // Immediate run fallback for first paint
    initLoaders();
</script>
