---
import SkeletonLoader from "../atoms/SkeletonLoader.astro";

interface Props {
    type?: "article" | "card" | "text" | "author-header" | "author-card";
    class?: string;
    minHeight?: string; // Allow overriding min-height
}

const {
    type = "article",
    class: className,
    minHeight = "min-h-[50vh]",
} = Astro.props;
---

<div class={`wp-loader-container relative ${minHeight} ${className}`}>
    <!-- Skeleton Overlay -->
    <div
        class="wp-loader-skeleton absolute inset-0 z-10 bg-[var(--ilsa-bg-light)] pointer-events-none"
        aria-hidden="true"
    >
        <SkeletonLoader type={type} />
    </div>

    <!-- Real Content -->
    <div class="wp-loader-content opacity-0 h-full w-full">
        <slot />
    </div>
</div>

<style>
    /* CSS-only animation for reliable loading without JS blocking */
    .wp-loader-skeleton {
        animation: fadeOutSkeleton 0.7s ease-out 0.3s forwards;
    }

    .wp-loader-content {
        animation: fadeInContent 0.7s ease-out 0.3s forwards;
    }

    @keyframes fadeOutSkeleton {
        from {
            opacity: 1;
            visibility: visible;
        }
        to {
            opacity: 0;
            visibility: hidden;
        }
    }

    @keyframes fadeInContent {
        from {
            opacity: 0;
            visibility: hidden;
        }
        to {
            opacity: 1;
            visibility: visible;
        }
    }
</style>
