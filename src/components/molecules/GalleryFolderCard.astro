---
// src/components/molecules/GalleryFolderCard.astro
import type { GalleryAlbum } from "../../lib/galleries";
import SmartImage from "../atoms/SmartImage.astro";

interface Props {
    album: GalleryAlbum;
}

const { album } = Astro.props;

// We show up to 4 images for the preview (2x2 grid)
const previewImages = album.images.slice(0, 4);

// This ensures we always have 4 elements to render the 2x2 grid correctly, 
// even if we pad with empty divs or fallbacks if album has less than 4 images.
const gridItems = Array.from({ length: 4 }).map((_, i) => previewImages[i] || null);

---

<button
    type="button"
    class="gallery-folder-trigger text-left group relative flex flex-col gap-4 p-5 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 shadow-lg hover:shadow-xl hover:bg-white/20 transition-all duration-300 w-full min-w-[280px]"
    data-album-id={album.id}
    aria-label={`Abrir álbum: ${album.title}`}
>
    <!-- Hidden JSON with album images for the modal to consume -->
    <script type="application/json" class="album-data" set:html={JSON.stringify(album)}></script>

    <!-- 2x2 Preview Grid -->
    <div class="grid grid-cols-2 grid-rows-2 gap-2 aspect-square w-full rounded-xl overflow-hidden bg-slate-100/50">
        {gridItems.map((img, idx) => (
            <div class={`relative w-full h-full bg-slate-200/50 overflow-hidden ${img ? '' : 'flex flex-col items-center justify-center text-slate-400'}`}>
                {img ? (
                    <SmartImage 
                        src={img.src} 
                        alt={img.alt || `Preview image ${idx + 1}`}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                    />
                ) : (
                    <svg class="w-6 h-6 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                )}
                {/* Overlay on the last image if there are more than 4 images */}
                {idx === 3 && album.images.length > 4 && (
                    <div class="absolute inset-0 bg-black/50 flex items-center justify-center text-white font-bold text-xl md:text-2xl backdrop-blur-[2px]">
                        +{album.images.length - 4}
                    </div>
                )}
            </div>
        ))}
    </div>

    <!-- Folder Info -->
    <div class="flex flex-col gap-1">
        <h3 class="font-bold text-slate-800 text-lg leading-tight group-hover:text-ilsa-blue transition-colors">
            {album.title}
        </h3>
        <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                {album.images.length}
            </span>
            {album.location && (
                <>
                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                    <span class="truncate">{album.location}</span>
                </>
            )}
        </div>
    </div>
</button>
