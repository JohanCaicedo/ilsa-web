---
// d:\.dev\ilsa-web\src\components\organisms\ColombiaMap.astro
import colombiaMapData from "@svg-maps/colombia";

const { viewBox, locations } = colombiaMapData;

// Configuración de los departamentos activos
const activeRegions: Record<string, { desc: string; href?: string }> = {
    met: { desc: "Región del Ariari" },
    cau: { desc: "Costa Pacífica nariñense y caucana" },
    boy: { desc: "Páramo de Pisba" },
    ant: { desc: "Región de Urabá" },
    san: { desc: "Provincia de Vélez" },
    nar: { desc: "Laguna de La Cocha" },
    sap: { desc: "Archipiélago de San Andrés y Providencia" },
    ama: { desc: "Leticia y cuenca amazónica" },
    bol: { desc: "Montes de María · Carmen de Bolívar, María la Baja" },
    suc: { desc: "Montes de María · departamento del Sucre" },
};
---

<div class="relative w-full flex items-center justify-center col-map-container">
    <svg
        viewBox={viewBox}
        class="w-full h-auto max-h-[650px] filter drop-shadow-md py-4"
        xmlns="http://www.w3.org/2000/svg"
    >
        {
            locations
                .filter((loc: any) => loc.id !== "sap")
                .map((loc: any) => {
                    const isActive = activeRegions[loc.id];

                    return (
                        <path
                            id={loc.id}
                            d={loc.path}
                            data-name={loc.name}
                            data-desc={isActive ? isActive.desc : ""}
                            class={`
                                stroke-white stroke-[1px] transition-colors duration-300 motion-reduce:transition-none
                                ${
                                    isActive
                                        ? "fill-[#4E7CCE]/70 hover:fill-[#4E7CCE] hover:stroke-2 cursor-pointer col-map-active"
                                        : "fill-slate-300/40 pointer-events-none"
                                }
                            `}
                        />
                    );
                })
        }
    </svg>

    <!-- Inset Map San Andrés y Providencia (Liquid Glass) -->
    <div class="absolute top-4 left-4 w-32 sm:w-40 md:w-48 bg-white/40 backdrop-blur-md border border-white/60 rounded-2xl shadow-[0_8px_32px_0_rgba(74,125,191,0.15)] p-3 flex flex-col gap-2 z-10 select-none">
        <span class="text-[9px] sm:text-[11px] font-bold text-[#183069] text-center border-b border-white/40 pb-1.5 leading-tight uppercase tracking-wider">
            San Andrés y Providencia
        </span>
        <div class="relative flex items-center justify-center p-1">
            <svg
                viewBox="0 0 887.39 971.18"
                class="w-full h-auto max-h-[120px] md:max-h-[160px]"
                xmlns="http://www.w3.org/2000/svg"
            >
                <!-- Cayos y Arrecifes (Decorative) -->
                <!-- Cayo Bolívar y Alburquerque, etc. (cls-3 / path2713) -->
                <path
                    d="M803.43,233h-6.02l-5.29,3.53-2.06-1.62,1.62-2.5-1.62-8.23-3.82-2.94-1.32-2.94,1.91-2.2,1.91-6.02-.29-3.08,3.38-2.35,2.64,2.06-.59,3.53,7.34,8.81-.73,3.67,4.11,4.26.88,4.85-2.06,1.18h0Z"
