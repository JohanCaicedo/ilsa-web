---
import SmartImage from "../atoms/SmartImage.astro";

const stages = [
  {
    number: "01",
    title: "Surgimiento y Fundamentos",
    color: "#4e7cce",
    text: "El Instituto Latinoamericano para una Sociedad y un Derecho Alternativos (ILSA) es una organización no gubernamental creada en 1978 bajo el auspicio del Comité Jurídico Interamericano (IJC), principal órgano jurídico de la Organización de Estados Americanos (OEA), a partir de la convicción de que el derecho puede y debe ser una herramienta para impulsar transformaciones sociales y ampliar el acceso a la justicia para los sectores populares en América Latina y el Caribe.",
    image: "/images/multimedia-galeria/visita-chita-julio/visita-chita-julio-34.webp",
    imageAlt: "Orígenes de ILSA",
  },
  {
    number: "02",
    title: "Consolidación Institucional",
    color: "#5e3b69",
    text: "Durante la década de 1980, ILSA profundizó un desplazamiento hacia enfoques como el uso alternativo del derecho, los servicios legales innovadores y el servicio jurídico crítico, buscando romper con concepciones tradicionales de la práctica jurídica. En 1985 obtuvo personería jurídica en Colombia y estableció su sede principal en Bogotá, manteniendo su proyección regional.",
    image: "/images/Linea del tiempo.webp",
    imageAlt: "Consolidación Institucional",
  },
  {
    number: "03",
    title: "Práctica Crítica y Despliegue",
    color: "#e9b384",
    text: "Desde entonces, ILSA ha promovido una práctica crítica del derecho y una concepción integral de los derechos humanos mediante labores pedagógicas, acompañamiento jurídico y fortalecimiento organizativo junto a asociaciones campesinas, pueblos indígenas, comunidades negras, procesos de mujeres, víctimas del conflicto y población firmante de paz. Su trabajo se ha desplegado en distintas regiones de Colombia y a nivel regional a través de redes como CLACSO y la Comunidad Latinoamericana de Empoderamiento Jurídico.",
    image: "/images/evento-cartagena/evento-cartagena (18).jpg",
    imageAlt: "Práctica Crítica y Despliegue en Territorio",
  },
  {
    number: "04",
    title: "Plan Estratégico 2025-2027",
    color: "#64748b",
    text: "ILSA definió para el periodo 2025-2027 cuatro campos de acción: Conflicto interno y política de paz; Producción del territorio y conflictividades; Democracias contemporáneas, luchas sociales y derechos humanos; y Género, derechos de las mujeres y diversidades. Los adelanta a través de servicio legal, advocacy, ecología de saberes, investigación, alianzas estratégicas y comunicaciones.",
    image: "",
    imageAlt: "",
  },
];
---

<section
  class="mb-24 max-w-7xl mx-auto scroll-mt-32 relative px-6 lg:px-8"
  id="nuestra-historia"
>
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-tr from-[#4e7cce]/5 to-[#5e3b69]/5 rounded-full blur-[100px] pointer-events-none -z-10"></div>

  <!-- Header -->
  <div class="text-center mb-10 md:mb-14">
    <p class="text-[#4e7cce] font-bold text-sm tracking-widest uppercase mb-2">
      Memoria y Trayectoria
    </p>
    <h2 class="text-4xl text-center md:text-5xl font-bold text-[#3d3d47] mb-6">
      Historia Institucional
    </h2>
    <div class="w-24 h-1 bg-gradient-to-r from-[#4e7cce] to-[#5e3b69] mx-auto rounded-full"></div>
  </div>

  <!-- Slider -->
  <history-slider class="block relative">

    <!-- Slide viewport -->
    <div class="slider-viewport relative overflow-hidden rounded-2xl md:rounded-[2rem]">

      {stages.map((stage, index) => (
        <div
          class={`hs-slide absolute inset-0 w-full h-full transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] ${index === 0 ? 'hs-active' : ''}`}
          data-slide={index}
          data-color={stage.color}
        >
          <div class={`flex flex-col ${stage.image ? 'lg:flex-row' : ''} items-center gap-4 md:gap-8 lg:gap-12 h-full p-4 md:p-8 lg:p-10`}>

            {/* Image */}
            {stage.image && (
              <div class="w-full lg:w-5/12 shrink-0 slide-img">
                <div
                  class="w-full aspect-[16/9] md:aspect-[4/3] bg-white/30 backdrop-blur-2xl border border-white/50 rounded-xl md:rounded-[2rem] shadow-xl relative overflow-hidden group"
                  style={`box-shadow: 0 12px 40px -10px ${stage.color}25;`}
                >
                  <div
                    class="absolute inset-0 mix-blend-multiply z-10 pointer-events-none opacity-30 group-hover:opacity-5 transition-opacity duration-500"
                    style={`background: linear-gradient(135deg, ${stage.color}33, transparent);`}
                  ></div>
                  <SmartImage
                    src={stage.image}
                    alt={stage.imageAlt}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.2s] group-hover:scale-105"
                  />
                </div>
              </div>
            )}

            {/* Content */}
            <div class={`w-full ${stage.image ? 'lg:w-7/12' : ''} flex flex-col justify-center`}>
              <div class="slide-number inline-flex items-center gap-3 md:gap-4 mb-3 md:mb-4">
                <span
                  class="flex items-center justify-center w-10 h-10 md:w-14 md:h-14 rounded-xl md:rounded-2xl font-bold text-lg md:text-2xl border shadow-sm shrink-0"
                  style={`background: ${stage.color}15; color: ${stage.color}; border-color: ${stage.color}30;`}
                >
                  {stage.number}
                </span>
                <h3 class="text-lg md:text-2xl lg:text-3xl font-bold text-[#3d3d47] leading-tight">
                  {stage.title}
                </h3>
              </div>

              <div class="slide-text">
                <div class="p-4 md:p-6 lg:p-8 rounded-xl md:rounded-[1.5rem] bg-white/40 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 relative">
                  <div
                    class="absolute top-0 left-6 md:left-8 w-10 md:w-14 h-1 rounded-b-full"
                    style={`background: ${stage.color};`}
                  ></div>
                  <p class="text-[#3d3d47]/80 text-sm md:text-base leading-relaxed text-pretty">
                    {stage.text}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Navigation arrows (below viewport on mobile, beside on desktop) -->
    <div class="flex items-center justify-center gap-4 mt-5 md:mt-6">
      <button
        class="arrow-btn arrow-prev shrink-0 w-11 h-11 md:w-14 md:h-14 rounded-full bg-white/80 backdrop-blur-xl border border-white/60 shadow-lg flex items-center justify-center text-[#3d3d47] hover:bg-white hover:shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 group disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:scale-100 relative"
        aria-label="Etapa anterior"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="absolute inset-0 rounded-full border-2 border-[#4e7cce]/30 animate-[arrowPulse_2s_ease-in-out_infinite] pointer-events-none opacity-0 group-hover:opacity-100"></span>
      </button>

      <!-- Step dots (inline between arrows) -->
      <div class="flex items-center gap-1.5 md:gap-3">
        {stages.map((s, i) => (
          <button
            class="step-dot group relative flex items-center justify-center cursor-pointer"
            data-step={i}
            aria-label={`Ir a etapa ${s.number}: ${s.title}`}
          >
            <span
              class="w-8 h-8 md:w-11 md:h-11 rounded-full border-2 flex items-center justify-center text-[10px] md:text-xs font-bold transition-all duration-500"
              style={`border-color: ${i === 0 ? s.color : '#cbd5e1'}; background: ${i === 0 ? s.color : 'white'}; color: ${i === 0 ? 'white' : '#94a3b8'};`}
              data-dot-inner
            >
              {s.number}
            </span>
            {i < stages.length - 1 && (
              <div class="w-4 md:w-12 h-[2px] bg-slate-200 ml-1.5 md:ml-3 relative overflow-hidden">
                <div class="dot-fill absolute inset-y-0 left-0 w-0 transition-all duration-700" style={`background: ${s.color};`}></div>
              </div>
            )}
          </button>
        ))}
      </div>

      <button
        class="arrow-btn arrow-next shrink-0 w-11 h-11 md:w-14 md:h-14 rounded-full bg-white/80 backdrop-blur-xl border border-white/60 shadow-lg flex items-center justify-center text-[#3d3d47] hover:bg-white hover:shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 group disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:scale-100 relative"
        aria-label="Siguiente etapa"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="absolute inset-0 rounded-full border-2 border-[#4e7cce]/30 animate-[arrowPulse_2s_ease-in-out_infinite] pointer-events-none"></span>
      </button>
    </div>

    <!-- Stage title preview -->
    <div class="mt-3 md:mt-4 text-center">
      <p class="stage-label text-xs md:text-sm font-semibold text-[#3d3d47]/60 transition-all duration-300">
        {stages[0].title}
      </p>
    </div>

  </history-slider>
</section>

<style>
  /* Slides: hidden by default, active one shown */
  .hs-slide {
    opacity: 0;
    pointer-events: none;
    transform: translateX(60px) scale(0.97);
  }
  .hs-slide.hs-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0) scale(1);
    position: relative;
  }

  /* Staggered inner elements */
  .hs-active .slide-img {
    animation: slideElIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.1s both;
  }
  .hs-active .slide-number {
    animation: slideElIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.25s both;
  }
  .hs-active .slide-text {
    animation: slideElIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.4s both;
  }

  @keyframes slideElIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes arrowPulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.4;
    }
    50% {
      transform: scale(1.3);
      opacity: 0;
    }
  }
</style>

<script>
  class HistorySlider extends HTMLElement {
    private slides!: HTMLElement[];
    private prevBtn!: HTMLButtonElement;
    private nextBtn!: HTMLButtonElement;
    private stepDots!: HTMLElement[];
    private dotFills!: HTMLElement[];
    private stageLabel!: HTMLElement;
    private current = 0;
    private transitioning = false;
    private titles: string[] = [];
    private colors: string[] = [];

    connectedCallback() {
      this.slides = Array.from(this.querySelectorAll('.hs-slide'));
      this.prevBtn = this.querySelector('.arrow-prev')!;
      this.nextBtn = this.querySelector('.arrow-next')!;
      this.stepDots = Array.from(this.querySelectorAll('.step-dot'));
      this.dotFills = Array.from(this.querySelectorAll('.dot-fill'));
      this.stageLabel = this.querySelector('.stage-label')!;

      this.titles = this.slides.map(s => {
        const h3 = s.querySelector('h3');
        return h3?.textContent?.trim() || '';
      });
      this.colors = this.slides.map(s => s.dataset.color || '#4e7cce');

      // Arrow clicks
      this.prevBtn.addEventListener('click', () => this.go(this.current - 1));
      this.nextBtn.addEventListener('click', () => this.go(this.current + 1));

      // Dot clicks
      this.stepDots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.dataset.step);
          if (idx !== this.current) this.go(idx);
        });
      });

      // Keyboard
      this.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') this.go(this.current - 1);
        if (e.key === 'ArrowRight') this.go(this.current + 1);
      });

      // Swipe support
      let touchStartX = 0;
      const viewport = this.querySelector('.slider-viewport')!;
      viewport.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).touches[0].clientX;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          this.go(diff > 0 ? this.current + 1 : this.current - 1);
        }
      }, { passive: true });

      this.updateButtons();
      this.updateDots();
    }

    go(targetIndex: number) {
      if (this.transitioning) return;
      if (targetIndex < 0 || targetIndex >= this.slides.length) return;
      if (targetIndex === this.current) return;

      this.transitioning = true;
      const goingForward = targetIndex > this.current;
      const oldSlide = this.slides[this.current];
      const newSlide = this.slides[targetIndex];

      // 1. Animate old slide OUT
      oldSlide.classList.remove('hs-active');
      oldSlide.style.opacity = '0';
      oldSlide.style.transform = goingForward
        ? 'translateX(-60px) scale(0.97)'
        : 'translateX(60px) scale(0.97)';

      // 2. Position new slide at entry point (no transition yet)
      newSlide.style.transition = 'none';
      newSlide.style.opacity = '0';
      newSlide.style.transform = goingForward
        ? 'translateX(60px) scale(0.97)'
        : 'translateX(-60px) scale(0.97)';

      // 3. Force reflow, then animate new slide IN
      newSlide.offsetHeight; // force reflow
      newSlide.style.transition = '';
      newSlide.classList.add('hs-active');
      newSlide.style.opacity = '';
      newSlide.style.transform = '';

      this.current = targetIndex;
      this.updateButtons();
      this.updateDots();

      // 4. Clean up old slide after transition ends
      setTimeout(() => {
        oldSlide.style.opacity = '';
        oldSlide.style.transform = '';
        this.transitioning = false;
      }, 750);
    }

    updateButtons() {
      this.prevBtn.disabled = this.current === 0;
      this.nextBtn.disabled = this.current === this.slides.length - 1;

      // Update arrow color to match current stage
      const color = this.colors[this.current];
      const nextPulse = this.nextBtn.querySelector('span');
      const prevPulse = this.prevBtn.querySelector('span');
      if (nextPulse) nextPulse.style.borderColor = `${color}50`;
      if (prevPulse) prevPulse.style.borderColor = `${color}50`;
    }

    updateDots() {
      const color = this.colors[this.current];

      this.stepDots.forEach((dot, i) => {
        const inner = dot.querySelector('[data-dot-inner]') as HTMLElement;
        const stageColor = this.colors[i];

        if (i === this.current) {
          inner.style.borderColor = stageColor;
          inner.style.background = stageColor;
          inner.style.color = '#fff';
          inner.style.transform = 'scale(1.15)';
          inner.style.boxShadow = `0 0 16px ${stageColor}40`;
        } else if (i < this.current) {
          inner.style.borderColor = stageColor;
          inner.style.background = stageColor;
          inner.style.color = '#fff';
          inner.style.transform = 'scale(1)';
          inner.style.boxShadow = 'none';
        } else {
          inner.style.borderColor = '#cbd5e1';
          inner.style.background = '#fff';
          inner.style.color = '#94a3b8';
          inner.style.transform = 'scale(1)';
          inner.style.boxShadow = 'none';
        }
      });

      // Fill connector lines
      this.dotFills.forEach((fill, i) => {
        fill.style.width = i < this.current ? '100%' : '0%';
      });

      // Update stage label
      if (this.stageLabel) {
        this.stageLabel.style.opacity = '0';
        setTimeout(() => {
          this.stageLabel.textContent = this.titles[this.current];
          this.stageLabel.style.color = color;
          this.stageLabel.style.opacity = '1';
        }, 150);
      }
    }
  }

  customElements.define('history-slider', HistorySlider);
</script>
